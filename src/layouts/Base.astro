---
export interface Props {
  title?: string;
  description?: string;
}
const { 
  title = 'matterunknown', 
  description = 'A think tank obsessed with identity — technical, narrative, human.' 
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title === 'matterunknown' ? title : `${title} — matterunknown`}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <slot />
</body>
</html>
