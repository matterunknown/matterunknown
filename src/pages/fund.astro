---
import Base from '../layouts/Base.astro';
---
<Base title="Fund Vessel">
  <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:24px;padding:68px var(--gutter) 80px;text-align:center;">
    <div style="font-family:var(--mono);font-size:.62rem;color:var(--amber);letter-spacing:.16em;text-transform:uppercase;">fund / matterunknown</div>
    <h1 style="font-family:var(--serif);font-size:clamp(3rem,6vw,5rem);font-weight:400;letter-spacing:-.025em;">Fund Vessel</h1>
    <p style="font-family:var(--mono);font-size:.72rem;color:var(--text-3);letter-spacing:.08em;">Building in public. This page is next.</p>
    <a href="/" style="font-family:var(--mono);font-size:.65rem;color:var(--amber);letter-spacing:.1em;text-transform:uppercase;margin-top:20px;">Back home</a>
  </div>
</Base>
