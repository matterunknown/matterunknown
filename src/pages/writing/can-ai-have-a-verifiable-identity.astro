<Base title="Can an AI Agent Have a Verifiable Identity?" description="We built a lab to find out. Not a theoretical exercise — a running system where AI agents register, attest, and get governed by cryptographic identity primitives.">
<style>
:root {
  --bg:           #090908;
  --bg-2:         #0d0d0b;
  --bg-3:         #121210;
  --amber:        #c4972a;
  --amber-dim:    rgba(196,151,42,0.12);
  --amber-border: rgba(196,151,42,0.15);
  --vessel:       #7eb8c4;
  --vessel-dim:   rgba(126,184,196,.08);
  --vessel-border:rgba(126,184,196,.12);
  --text:         #e8e6e1;
  --text-2:       #a09c94;
  --text-3:       #5a5752;
  --serif:        'DM Serif Display', Georgia, serif;
  --sans:         'DM Sans', system-ui, sans-serif;
  --mono:         'JetBrains Mono', ui-monospace, monospace;
  --gutter:       clamp(24px, 5vw, 80px);
  --max:          680px;
  --nav-h:        68px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: var(--sans); font-weight: 300; line-height: 1.7; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
nav { position:fixed;top:0;left:0;right:0;z-index:200;height:var(--nav-h);display:flex;align-items:center;justify-content:space-between;padding:0 var(--gutter);border-bottom:1px solid transparent;transition:all .4s; }
nav.scrolled { border-color:var(--amber-border);background:rgba(9,9,8,.93);backdrop-filter:blur(14px); }
.nav-logo { font-family:var(--serif);font-size:1.05rem;color:var(--text); }
.nav-logo span { color:var(--amber); }
a { color:inherit;text-decoration:none; }
.article { max-width:var(--max);margin:0 auto;padding:calc(var(--nav-h) + 80px) var(--gutter) 120px; }
.article-label { font-family:var(--mono);font-size:.62rem;color:var(--amber);letter-spacing:.16em;text-transform:uppercase;margin-bottom:28px; }
h1 { font-family:var(--serif);font-size:clamp(2.2rem,5vw,3.6rem);font-weight:400;line-height:1.1;letter-spacing:-.025em;margin-bottom:20px; }
.article-meta { font-family:var(--mono);font-size:.62rem;color:var(--text-3);letter-spacing:.07em;margin-bottom:64px;padding-bottom:40px;border-bottom:1px solid var(--amber-border); }
h2 { font-family:var(--serif);font-size:1.5rem;font-weight:400;letter-spacing:-.015em;margin:56px 0 20px; }
p { color:var(--text-2);margin-bottom:24px;font-size:1.02rem;line-height:1.8; }
p strong { color:var(--text);font-weight:500; }
blockquote { border-left:2px solid var(--amber);margin:40px 0;padding:0 0 0 24px; }
blockquote p { color:var(--text);font-style:italic;font-size:1.05rem; }
code { font-family:var(--mono);font-size:.82em;background:var(--bg-3);border:1px solid var(--amber-border);padding:2px 7px;border-radius:3px;color:var(--amber); }
.article-footer { margin-top:80px;padding-top:40px;border-top:1px solid var(--amber-border); }
.back-link { font-family:var(--mono);font-size:.65rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;transition:color .2s; }
.back-link:hover { color:var(--amber); }
@media(max-width:768px) { .article { padding-left:24px;padding-right:24px; } }
</style>

