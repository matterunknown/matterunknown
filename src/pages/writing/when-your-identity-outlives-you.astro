<Base title="When Your Identity Outlives You" description="Digital identity doesn't die when you do. The gap between death and deletion is a security threat — not dramatic, not a breach, just slow entropy.">
<style>

  :root {
    --bg:      #090908;
    --bg-2:    #0d0d0b;
    --bg-3:    #121210;
    --amber:   #c4972a;
    --amber-2: #d4aa45;
    --text-1:  #e8e6e1;
    --text-2:  #a09c94;
    --text-3:  #5a5752;
    --serif:   'DM Serif Display', Georgia, serif;
    --sans:    'DM Sans', system-ui, sans-serif;
    --mono:    'JetBrains Mono', 'Courier New', monospace;
    --max-w:   680px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { background: var(--bg); color: var(--text-1); font-family: var(--sans); font-size: 16px; line-height: 1.7; -webkit-font-smoothing: antialiased; }

  body { background: var(--bg); min-height: 100vh; }

  /* NAV */
  #nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.25rem 2rem;
    transition: background .25s, border-color .25s;
    border-bottom: 1px solid transparent;
  }
  #nav.scrolled {
    background: rgba(9,9,8,.92);
    backdrop-filter: blur(12px);
    border-color: rgba(255,255,255,.05);
  }
  .nav-logo {
    font-family: var(--mono);
    font-size: .75rem;
    letter-spacing: .12em;
    text-transform: lowercase;
    color: var(--text-2);
    text-decoration: none;
    transition: color .2s;
  }
  .nav-logo span { color: var(--amber); }
  .nav-logo:hover { color: var(--text-1); }

  /* ARTICLE */
  .article {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 8rem 1.5rem 6rem;
  }

  .article-label {
    font-family: var(--mono);
    font-size: .6rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 1.5rem;
  }

  .article h1 {
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--text-1);
    margin-bottom: 1.25rem;
    letter-spacing: -.01em;
  }

  .article-meta {
    font-family: var(--mono);
    font-size: .6rem;
    letter-spacing: .1em;
    color: var(--text-3);
    text-transform: uppercase;
    margin-bottom: 3.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255,255,255,.06);
  }

  .article h2 {
    font-family: var(--serif);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--text-1);
    margin: 3rem 0 1rem;
    letter-spacing: -.01em;
  }

  .article p {
    color: var(--text-2);
    margin-bottom: 1.4rem;
    font-size: .975rem;
    line-height: 1.8;
  }

  .article p strong {
    color: var(--text-1);
    font-weight: 500;
  }

  .article blockquote {
    border-left: 2px solid var(--amber);
    margin: 2.5rem 0;
    padding: .75rem 0 .75rem 1.5rem;
  }
  .article blockquote p {
    color: var(--text-1);
    font-style: italic;
    font-size: 1.05rem;
    margin: 0;
    line-height: 1.65;
  }

  .article code {
    font-family: var(--mono);
    font-size: .8rem;
    color: var(--amber-2);
    background: var(--bg-3);
    padding: .15em .4em;
    border-radius: 3px;
  }

  .article-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,.06);
  }

  .back-link {
    font-family: var(--mono);
    font-size: .65rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--text-3);
    text-decoration: none;
    transition: color .2s;
  }
  .back-link:hover { color: var(--amber); }
</style>

