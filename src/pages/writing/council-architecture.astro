}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: var(--sans); font-weight: 300; line-height: 1.7; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
nav { position:fixed;top:0;left:0;right:0;z-index:200;height:var(--nav-h);display:flex;align-items:center;justify-content:space-between;padding:0 var(--gutter);border-bottom:1px solid transparent;transition:all .4s; }
nav.scrolled { border-color:var(--amber-border);background:rgba(9,9,8,.93);backdrop-filter:blur(14px); }
.nav-logo { font-family:var(--serif);font-size:1.05rem;color:var(--text); }
.nav-logo span { color:var(--amber); }
.article { max-width:680px;margin:0 auto;padding:calc(var(--nav-h) + 80px) var(--gutter) 120px; }
.article-label { font-family:var(--mono);font-size:.6rem;color:var(--amber);letter-spacing:.16em;text-transform:uppercase;margin-bottom:20px;display:flex;align-items:center;gap:12px; }
.article-label::before { content:'';width:20px;height:1px;background:var(--amber); }
h1 { font-family:var(--serif);font-size:clamp(2.2rem,5vw,3.5rem);font-weight:400;line-height:1.1;letter-spacing:-.025em;margin-bottom:32px; }
.article-meta { font-family:var(--mono);font-size:.62rem;color:var(--text-3);letter-spacing:.08em;margin-bottom:64px;padding-bottom:32px;border-bottom:1px solid var(--amber-border); }
.article p { color:var(--text-2);font-size:1.05rem;line-height:1.9;margin-bottom:28px; }
.article p em { color:var(--text);font-style:italic; }
.article p strong { color:var(--text);font-weight:400; }
.article h2 { font-family:var(--serif);font-size:1.6rem;font-weight:400;letter-spacing:-.02em;margin:56px 0 20px; }
.article blockquote { border-left:2px solid var(--amber);padding-left:24px;margin:40px 0;font-family:var(--serif);font-size:1.15rem;font-style:italic;color:var(--text-2);line-height:1.7; }
.article code { font-family:var(--mono);font-size:.82rem;background:var(--amber-dim);border:1px solid var(--amber-border);padding:2px 7px;color:var(--amber); }
.agent-grid { display:grid;grid-template-columns:1fr 1fr;gap:2px;margin:40px 0; }
.agent-card { background:var(--bg-2);border:1px solid var(--amber-border);padding:20px 22px; }
.agent-card.vessel { border-color:var(--vessel-border);background:var(--vessel-dim); }
.agent-label { font-family:var(--mono);font-size:.56rem;color:var(--amber);letter-spacing:.14em;text-transform:uppercase;margin-bottom:6px; }
.agent-card.vessel .agent-label { color:var(--vessel); }
.agent-name { font-family:var(--serif);font-size:1.05rem;color:var(--text);margin-bottom:4px; }
.agent-desc { font-family:var(--mono);font-size:.62rem;color:var(--text-3);line-height:1.65; }
.article-footer { margin-top:80px;padding-top:40px;border-top:1px solid var(--amber-border);display:flex;align-items:center;justify-content:space-between; }
.back-link { font-family:var(--mono);font-size:.65rem;color:var(--amber);letter-spacing:.1em;text-transform:uppercase;text-decoration:none; }
@media(max-width:600px) { .agent-grid { grid-template-columns:1fr; } }
