nav { position:fixed;top:0;left:0;right:0;z-index:200;height:var(--nav-h);display:flex;align-items:center;justify-content:space-between;padding:0 var(--gutter);border-bottom:1px solid transparent;transition:all .4s; }
nav.scrolled { border-color:rgba(126,184,196,.12);background:rgba(9,9,8,.93);backdrop-filter:blur(14px); }
.nav-logo { font-family:var(--serif);font-size:1.05rem;color:var(--text); }
.nav-logo span { color:var(--amber); }
:root {
  --bg:           #090908;
  --bg-2:         #0d0d0b;
  --bg-3:         #121210;
  --amber:        #c4972a;
  --amber-dim:    rgba(196,151,42,0.12);
  --amber-border: rgba(196,151,42,0.15);
  --vessel:       #7eb8c4;
  --vessel-dim:   rgba(126,184,196,.08);
  --vessel-border:rgba(126,184,196,.12);
  --vessel-glow:  rgba(126,184,196,.04);
  --text:         #e8e6e1;
  --text-2:       #a09c94;
  --text-3:       #5a5752;
  --serif:        'DM Serif Display', Georgia, serif;
  --sans:         'DM Sans', system-ui, sans-serif;
  --mono:         'JetBrains Mono', ui-monospace, monospace;
  --gutter:       clamp(24px, 5vw, 80px);
  --max:          1160px;
  --nav-h:        68px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: var(--sans); font-weight: 300; line-height: 1.7; -webkit-font-smoothing: antialiased; overflow-x: hidden; }

.article { max-width:680px;margin:0 auto;padding:calc(var(--nav-h) + 80px) var(--gutter) 120px; }
.article-label { font-family:var(--mono);font-size:.6rem;color:var(--vessel);letter-spacing:.16em;text-transform:uppercase;margin-bottom:20px;display:flex;align-items:center;gap:12px; }
.article-label::before { content:'';width:20px;height:1px;background:var(--vessel); }
.article h1 { font-family:var(--serif);font-size:clamp(2.2rem,5vw,3.5rem);font-weight:400;line-height:1.1;letter-spacing:-.025em;margin-bottom:32px; }
.article-meta { font-family:var(--mono);font-size:.62rem;color:var(--text-3);letter-spacing:.08em;margin-bottom:64px;padding-bottom:32px;border-bottom:1px solid var(--vessel-border); }
.article p { color:var(--text-2);font-size:1.05rem;line-height:1.9;margin-bottom:28px; }
.article p em { color:var(--text);font-style:italic; }
.article h2 { font-family:var(--serif);font-size:1.6rem;font-weight:400;letter-spacing:-.02em;margin:56px 0 20px;color:var(--text); }
.article blockquote { border-left:2px solid var(--vessel);padding-left:24px;margin:40px 0;font-family:var(--serif);font-size:1.15rem;font-style:italic;color:var(--text-2);line-height:1.7; }
.article code { font-family:var(--mono);font-size:.82rem;background:rgba(126,184,196,.08);border:1px solid var(--vessel-border);padding:2px 7px;color:var(--vessel); }
.article-footer { margin-top:80px;padding-top:40px;border-top:1px solid var(--vessel-border);display:flex;align-items:center;justify-content:space-between; }
.back-link { font-family:var(--mono);font-size:.65rem;color:var(--vessel);letter-spacing:.1em;text-transform:uppercase;text-decoration:none;transition:gap .2s;display:flex;align-items:center;gap:8px; }
.back-link:hover { gap:14px; }
.vessel-sig { font-family:var(--serif);font-size:.9rem;font-style:italic;color:var(--text-3); }
</style>

