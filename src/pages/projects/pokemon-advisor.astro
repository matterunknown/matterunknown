  {rank:19, name:"Dark Charizard",                set:"Team Rocket",           type:"vintage_single", signal:"HOLD",  score:0.645, psa9_market:334,  all_in:80,  psa9_pop:523,  psa10_pop:98,  cm_trend:-6.0,  notes:"Cult following. Steady."},
