  {rank:22, name:"Team Rocket's Mewtwo ex SIR",   set:"Destined Rivals",       type:"modern_single",  signal:"HOLD",  score:0.620, psa9_market:500,  all_in:550, psa9_pop:0,    psa10_pop:0,   cm_trend:0,     notes:"Gen 1 nostalgia + Team Rocket."},
  {rank:23, name:"Gengar VMAX Alt Art",           set:"Fusion Strike",         type:"modern_single",  signal:"HOLD",  score:0.610, psa9_market:700,  all_in:750, psa9_pop:0,    psa10_pop:0,   cm_trend:0,     notes:"Gengar tax. SWSH rotation amplifies scarcity."},
  {rank:24, name:"Prismatic Evolutions ETB",      set:"Prismatic Evolutions",  type:"sealed",         signal:"HOLD",  score:0.597, psa9_market:190,  all_in:190, psa9_pop:0,    psa10_pop:0,   cm_trend:0,     notes:"Already reprinted heavily."},
  {rank:25, name:"Moonbreon (Umbreon VMAX Alt Art)",set:"Evolving Skies",      type:"modern_single",  signal:"HOLD",  score:0.595, psa9_market:1771, all_in:1821,psa9_pop:0,    psa10_pop:0,   cm_trend:0,     notes:"449% long-term appreciation. Blue chip but high entry."},
];

// Aliases for fuzzy matching
const ALIASES = {
  "moonbreon": "Moonbreon (Umbreon VMAX Alt Art)",
  "umbreon vmax": "Moonbreon (Umbreon VMAX Alt Art)",
  "umbreon vmax alt art": "Moonbreon (Umbreon VMAX Alt Art)",
  "umbreon ex": "Umbreon ex SIR 161",
  "bubble mew": "Crown Zenith Mew VSTAR Rainbow",
  "mew vstar": "Crown Zenith Mew VSTAR Rainbow",
  "blaines charizard": "Blaine's Charizard",
  "blaine charizard": "Blaine's Charizard",
  "shining mewtwo": "Shining Mewtwo",
  "shining charizard": "Shining Charizard",
  "shining gyarados": "Shining Gyarados",
  "shining magikarp": "Shining Magikarp",
  "neo lugia": "Lugia",
  "neo genesis lugia": "Lugia",
  "dark charizard": "Dark Charizard",
  "mega gengar": "Mega Gengar ex SIR",
  "mega dragonite": "Mega Dragonite ex SIR",
  "team rockets mewtwo": "Team Rocket's Mewtwo ex SIR",
  "rockets mewtwo": "Team Rocket's Mewtwo ex SIR",
  "gengar vmax": "Gengar VMAX Alt Art",
  "evolving skies etb": "Evolving Skies ETB",
  "ascended heroes etb": "Ascended Heroes ETB",
  "destined rivals etb": "Destined Rivals ETB",
  "crown zenith etb": "Crown Zenith ETB",
  "prismatic evolutions etb": "Prismatic Evolutions ETB",
  "ho-oh": "Ho-Oh",
  "hooh": "Ho-Oh",
};

const SET_ALIASES = {
  "neo rev": "Neo Revelation",
  "neo dest": "Neo Destiny",
  "neo gen": "Neo Genesis",
  "gym chall": "Gym Challenge",
  "gym heroes": "Gym Heroes",
  "aqua": "Aquapolis",
  "sky": "Skyridge",
  "es": "Evolving Skies",
  "cz": "Crown Zenith",
  "pe": "Prismatic Evolutions",
  "dr": "Destined Rivals",
  "ah": "Ascended Heroes",
  "fs": "Fusion Strike",
};

// Example collections
const EXAMPLES = {
  beginner: `Ho-Oh Neo Revelation raw NM
Entei Neo Revelation raw
Raikou Neo Revelation raw
Evolving Skies ETB sealed`,

  neo: `Ho-Oh Neo Revelation PSA 9
Suicune Neo Revelation PSA 9
Raikou Neo Revelation raw NM
Entei Neo Revelation raw NM
Shining Magikarp Neo Destiny raw
Lugia Neo Genesis raw`,

  modern: `Moonbreon PSA 9
Umbreon ex SIR 161 raw
Evolving Skies ETB sealed
Prismatic Evolutions ETB sealed
Mega Gengar ex SIR raw`,
};

function loadExample(type) {
  document.getElementById('collection-input').value = EXAMPLES[type];
}

// ─── Collection parser ───────────────────────────────────────────
function parseCollection(text) {
  const lines = text.split('\n').map(l => l.trim()).filter(l => l.length > 2);
  const parsed = [];

  for (const line of lines) {
    const lower = line.toLowerCase()
      .replace(/['']/g, "'")
      .replace(/[^a-z0-9\s'\-\.]/g, ' ')
      .replace(/\s+/g, ' ')
      .trim();

    // Extract grade/condition
    let grade = 'unknown';
    let graded = false;
    if (/psa\s*10/.test(lower)) { grade = 'PSA 10'; graded = true; }
    else if (/psa\s*9\.5/.test(lower)) { grade = 'PSA 9.5'; graded = true; }
    else if (/psa\s*9/.test(lower)) { grade = 'PSA 9'; graded = true; }
    else if (/psa\s*8/.test(lower)) { grade = 'PSA 8'; graded = true; }
    else if (/psa\s*[0-9]/.test(lower)) { grade = 'PSA graded'; graded = true; }
    else if (/bgs|beckett/.test(lower)) { grade = 'BGS'; graded = true; }
    else if (/cgc/.test(lower)) { grade = 'CGC'; graded = true; }
    else if (/sealed|unopened/.test(lower)) { grade = 'Sealed'; }
    else if (/nm|near mint|mint/.test(lower)) { grade = 'NM raw'; }
    else if (/lp|lightly played/.test(lower)) { grade = 'LP raw'; }
    else if (/raw|ungraded/.test(lower)) { grade = 'raw'; }

    // Try alias match first
    let matched = null;
    for (const [alias, canonical] of Object.entries(ALIASES)) {
      if (lower.includes(alias)) {
        // Find in model
        const modelCard = MODEL.find(m =>
          m.name.toLowerCase() === canonical.toLowerCase()
        );
        if (modelCard) {
          // Try to match set if specified
          let setMatch = modelCard.set;
          for (const [sa, sf] of Object.entries(SET_ALIASES)) {
            if (lower.includes(sa)) setMatch = sf;
          }
          // Check if a different card with same name but different set
          const setSpecific = MODEL.find(m =>
            m.name.toLowerCase() === canonical.toLowerCase() &&
            (lower.includes(m.set.toLowerCase()) || lower.includes(setMatch.toLowerCase()))
          );
          matched = {
            raw: line,
            name: modelCard.name,
            set: (setSpecific || modelCard).set,
            grade,
            graded,
            modelCard: setSpecific || modelCard,
            inModel: true,
          };
          break;
        }
      }
    }

    // Direct name match if no alias hit
    if (!matched) {
      for (const card of MODEL) {
        const cardLower = card.name.toLowerCase();
        if (lower.includes(cardLower) || cardLower.includes(lower.split(' ').slice(0,2).join(' '))) {
          // Check set match
          const setMatch = lower.includes(card.set.toLowerCase()) ||
            Object.entries(SET_ALIASES).some(([alias, full]) =>
              lower.includes(alias) && full.toLowerCase() === card.set.toLowerCase()
            );
          matched = {
            raw: line,
            name: card.name,
            set: card.set,
            grade,
            graded,
            modelCard: card,
            inModel: true,
          };
          if (setMatch) break; // prefer set-specific match
        }
      }
    }

    // Unrecognized card — still track it
    if (!matched) {
      matched = {
        raw: line,
        name: line.replace(/psa\s*\d+\.?\d*|raw|nm|near mint|sealed|ungraded|lp|graded/gi, '').trim(),
        set: 'Unknown',
        grade,
        graded,
        modelCard: null,
        inModel: false,
      };
    }

    parsed.push(matched);
  }

  return parsed;
}

// ─── Recommendation engine ───────────────────────────────────────
function generateRecommendations(collection) {
  const ownedNames = new Set(collection.filter(c => c.inModel).map(c => `${c.name}|${c.set}`));
  const ownedRaw   = new Set(collection.filter(c => c.inModel && !c.graded && c.grade !== 'Sealed').map(c => `${c.name}|${c.set}`));
  const ownedGraded = new Set(collection.filter(c => c.inModel && c.graded).map(c => `${c.name}|${c.set}`));

  const recs = [];

  // 1. Upgrade paths — raw cards that should be graded
  const upgradeTargets = collection.filter(c =>
    c.inModel && !c.graded && c.grade !== 'Sealed' &&
    (c.modelCard.signal === 'BUY' || c.modelCard.signal === 'WATCH') &&
    c.modelCard.psa9_market > 100
  );
  for (const card of upgradeTargets) {
    const m = card.modelCard;
    const roi = m.psa9_market > 0 ? ((m.psa9_market - m.all_in) / m.all_in * 100).toFixed(0) : null;
    recs.push({
      type: 'upgrade',
      priority: 1,
      card: m,
      owned: card,
      headline: `Grade your ${m.name} (${m.set})`,
      reason: `You own this raw — it's a ${m.signal} signal with PSA 9 market at $${m.psa9_market.toLocaleString()}. ${roi ? `Potential ${roi}% return on grading cost.` : ''} Submit to PSA now.`,
      action: 'PSA submission',
    });
  }

  // 2. Set completion — cards in the same set/theme
  const neoRevOwned = collection.filter(c => c.set === 'Neo Revelation' || (c.inModel && c.modelCard?.set === 'Neo Revelation'));
  const neoRevCards = MODEL.filter(m => m.set === 'Neo Revelation');
  const neoRevMissing = neoRevCards.filter(m => !ownedNames.has(`${m.name}|${m.set}`));
  if (neoRevOwned.length > 0 && neoRevMissing.length > 0) {
    for (const m of neoRevMissing) {
      recs.push({
        type: 'set_completion',
        priority: m.signal === 'BUY' ? 2 : m.signal === 'WATCH' ? 3 : 4,
        card: m,
        owned: null,
        headline: `Complete Neo Revelation: add ${m.name}`,
        reason: `You own ${neoRevOwned.length} Neo Revelation card${neoRevOwned.length > 1 ? 's' : ''}. ${m.name} is missing — ${m.signal} signal, score ${m.score.toFixed(3)}. ${m.psa9_market > 0 ? `PSA 9 at $${m.psa9_market}.` : ''} Completing the legendary beasts set adds coherence and value.`,
        action: `Buy ${m.grade !== 'unknown' ? 'raw on eBay or TCGplayer' : 'on eBay'}`,
      });
    }
  }

  const neoDestOwned = collection.filter(c => c.set === 'Neo Destiny' || (c.inModel && c.modelCard?.set === 'Neo Destiny'));
  const neoDestCards = MODEL.filter(m => m.set === 'Neo Destiny');
  const neoDestMissing = neoDestCards.filter(m => !ownedNames.has(`${m.name}|${m.set}`));
  if (neoDestOwned.length > 0 && neoDestMissing.length > 0) {
    for (const m of neoDestMissing) {
      recs.push({
        type: 'set_completion',
        priority: m.signal === 'BUY' ? 2 : 3,
        card: m,
        owned: null,
        headline: `Complete Neo Destiny Shinings: add ${m.name}`,
        reason: `You have Neo Destiny cards. The Shining series (${neoDestCards.map(c=>c.name).join(', ')}) is the highest-scarcity tier in the Neo era. ${m.name} — ${m.signal}, score ${m.score.toFixed(3)}.`,
        action: 'Buy raw on eBay',
      });
    }
  }

  // 3. Gap fills — BUY signals not in collection
  const buyGaps = MODEL.filter(m =>
    m.signal === 'BUY' && !ownedNames.has(`${m.name}|${m.set}`)
  );
  for (const m of buyGaps) {
    recs.push({
      type: 'gap_fill',
      priority: 2,
      card: m,
      owned: null,
      headline: `${m.name} (${m.set}) — not in your collection`,
      reason: `Model's #${m.rank} pick. Score ${m.score.toFixed(3)}. ${m.psa9_market > 0 ? `PSA 9 at $${m.psa9_market.toLocaleString()}, ~$${m.all_in} all-in to grade.` : ''} ${m.notes}`,
      action: m.type === 'sealed' ? 'Buy sealed' : 'Buy raw and grade',
    });
  }

  // 4. WATCH signals not in collection
  const watchGaps = MODEL.filter(m =>
    m.signal === 'WATCH' && !ownedNames.has(`${m.name}|${m.set}`)
  ).slice(0, 4);
  for (const m of watchGaps) {
    recs.push({
      type: 'watch',
      priority: 4,
      card: m,
      owned: null,
      headline: `Watch: ${m.name} (${m.set})`,
      reason: `Not in your collection yet. WATCH signal — score ${m.score.toFixed(3)}. ${m.notes}`,
      action: 'Monitor price',
    });
  }

  // 5. Diversification — if heavily vintage, suggest modern or sealed
  const vintageCount = collection.filter(c => c.inModel && c.modelCard?.type === 'vintage_single').length;
  const modernCount  = collection.filter(c => c.inModel && c.modelCard?.type === 'modern_single').length;
  const sealedCount  = collection.filter(c => c.inModel && c.modelCard?.type === 'sealed').length;

  if (vintageCount >= 3 && modernCount === 0) {
    const bestModern = MODEL.find(m => m.type === 'modern_single' && m.signal === 'BUY' && !ownedNames.has(`${m.name}|${m.set}`));
    if (bestModern) {
      recs.push({
        type: 'diversification',
        priority: 3,
        card: bestModern,
        owned: null,
        headline: `Diversify: add a modern card`,
        reason: `Your collection is vintage-heavy (${vintageCount} cards). Adding ${bestModern.name} (${bestModern.set}) gives you exposure to the modern market and a PSA 10 grading play. Raw at $${bestModern.psa9_market}, PSA 10s trading at 3-9x raw.`,
        action: 'Buy raw on TCGplayer',
      });
    }
  }

  if (sealedCount === 0 && (vintageCount + modernCount) >= 2) {
    const bestSealed = MODEL.find(m => m.type === 'sealed' && m.signal !== 'HOLD' && !ownedNames.has(`${m.name}|${m.set}`));
    if (bestSealed) {
      recs.push({
        type: 'diversification',
        priority: 4,
        card: bestSealed,
        owned: null,
        headline: `Consider sealed: ${bestSealed.name}`,
        reason: `No sealed product in your collection. ${bestSealed.name} at $${bestSealed.all_in} is the hold-and-appreciate play — buy sealed, store properly, sell when print run ends. Different risk profile to singles.`,
        action: 'Buy sealed, store flat',
      });
    }
  }

  // Sort by priority then score
  recs.sort((a, b) => a.priority - b.priority || b.card.score - a.card.score);
  return recs;
}

// ─── Render ──────────────────────────────────────────────────────
const SIG_COLOR  = {BUY:'#4caf50',WATCH:'#c4972a',HOLD:'#5a5752',AVOID:'#c45a5a'};
const TYPE_LABEL = {vintage_single:'🏛 Vintage',modern_single:'✨ Modern',sealed:'📦 Sealed'};
const REC_COLORS = {
  upgrade:        {border:'#7eb8c4', label:'Upgrade opportunity', labelColor:'#7eb8c4'},
  set_completion: {border:'#c4972a', label:'Set completion',      labelColor:'#c4972a'},
  gap_fill:       {border:'#4caf50', label:'Buy signal gap',      labelColor:'#4caf50'},
  watch:          {border:'#5a5752', label:'Watch list',          labelColor:'#5a5752'},
  diversification:{border:'#9b6bc4', label:'Diversification',     labelColor:'#9b6bc4'},
};

function renderCollectionCard(item) {
  const sig_c = item.inModel ? SIG_COLOR[item.modelCard.signal] : '#5a5752';
  const type_l = item.inModel ? TYPE_LABEL[item.modelCard.type] : '';
  const score  = item.inModel ? item.modelCard.score.toFixed(3) : '—';
  const signal = item.inModel ? item.modelCard.signal : '—';
  const grade_color = item.graded ? '#4caf50' : item.grade === 'Sealed' ? '#c4972a' : '#a09c94';

  return `<div style="background:#0d0d0b;border:1px solid rgba(255,255,255,.06);border-left:3px solid ${sig_c};padding:16px 20px;display:flex;align-items:center;justify-content:space-between;gap:16px">
    <div>
      <div style="font-family:'DM Serif Display',Georgia,serif;font-size:1rem;color:#e8e6e1;margin-bottom:3px">${item.name}</div>
      <div style="font-family:'JetBrains Mono',monospace;font-size:.58rem;color:#5a5752;letter-spacing:.07em">${item.set} &nbsp;·&nbsp; <span style="color:${grade_color}">${item.grade}</span> &nbsp;·&nbsp; ${type_l}</div>
    </div>
    <div style="text-align:right;flex-shrink:0">
      <div style="font-family:'JetBrains Mono',monospace;font-size:.58rem;color:${sig_c};border:1px solid ${sig_c}44;padding:2px 8px;letter-spacing:.1em;margin-bottom:4px">${signal}</div>
      <div style="font-family:'JetBrains Mono',monospace;font-size:.75rem;color:${sig_c}">${score}</div>
    </div>
  </div>`;
}

function renderRecCard(rec) {
  const rc = REC_COLORS[rec.type];
  const m  = rec.card;
  const price_str = m.psa9_market > 0 && m.type !== 'sealed'
    ? `<span style="color:#5a5752">PSA 9 ~$${m.psa9_market.toLocaleString()} &nbsp;·&nbsp; All-in ~$${m.all_in}</span>`
    : m.type === 'sealed' ? `<span style="color:#5a5752">Current ~$${m.all_in.toLocaleString()}</span>` : '';

  return `<div style="background:#0d0d0b;border:1px solid rgba(255,255,255,.06);border-left:3px solid ${rc.border};padding:24px 22px;margin-bottom:2px">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px">
      <div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:.56rem;color:${rc.labelColor};letter-spacing:.12em;text-transform:uppercase;margin-bottom:8px">${rc.label}</div>
        <div style="font-family:'DM Serif Display',Georgia,serif;font-size:1.15rem;color:#e8e6e1;letter-spacing:-.01em">${rec.headline}</div>
      </div>
      <div style="text-align:right;flex-shrink:0;margin-left:16px">
        <div style="font-family:'JetBrains Mono',monospace;font-size:.56rem;color:${SIG_COLOR[m.signal]};border:1px solid ${SIG_COLOR[m.signal]}44;padding:2px 8px;letter-spacing:.1em;margin-bottom:4px">${m.signal}</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:.8rem;color:${SIG_COLOR[m.signal]}">${m.score.toFixed(3)}</div>
      </div>
    </div>
    <div style="font-family:'JetBrains Mono',monospace;font-size:.68rem;color:#a09c94;line-height:1.75;margin-bottom:10px">${rec.reason}</div>
    <div style="display:flex;align-items:center;justify-content:space-between">
      ${price_str}
      <div style="font-family:'JetBrains Mono',monospace;font-size:.6rem;color:${rc.labelColor};letter-spacing:.08em;text-transform:uppercase">${rec.action} →</div>
    </div>
  </div>`;
}

// ─── Main analyze function ───────────────────────────────────────
function analyzeCollection() {
  const text = document.getElementById('collection-input').value.trim();
  if (!text) return;

  const collection = parseCollection(text);
  const recs = generateRecommendations(collection);

  const recognized = collection.filter(c => c.inModel);
  const unrecognized = collection.filter(c => !c.inModel);
  const upgrades  = recs.filter(r => r.type === 'upgrade');
  const gaps      = recs.filter(r => r.type === 'gap_fill');
  const setComps  = recs.filter(r => r.type === 'set_completion');
  const watches   = recs.filter(r => r.type === 'watch');
  const divers    = recs.filter(r => r.type === 'diversification');

  // Score the collection
  const collectionValue = recognized.reduce((sum, c) => {
    if (!c.modelCard) return sum;
    if (c.grade === 'PSA 9') return sum + c.modelCard.psa9_market;
    if (c.graded) return sum + c.modelCard.psa9_market * 0.7;
    if (c.grade === 'Sealed') return sum + c.modelCard.all_in;
    return sum + c.modelCard.all_in;
  }, 0);
  const avgScore = recognized.length > 0
    ? (recognized.reduce((s, c) => s + (c.modelCard?.score || 0), 0) / recognized.length).toFixed(3)
    : 0;

  // Training data — log to console (eventually we'll collect this)
  console.log('VESSEL_ADVISOR_SUBMISSION', {
    timestamp: new Date().toISOString(),
    collection_size: collection.length,
    recognized: recognized.length,
    cards: collection.map(c => ({name: c.name, set: c.set, grade: c.grade})),
    top_rec: recs[0]?.card?.name,
    session: Math.random().toString(36).slice(2,8),
  });

  let html = `
    <!-- Stats bar -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-bottom:48px">
      <div style="background:#0d0d0b;border:1px solid rgba(196,151,42,.15);padding:20px 18px;text-align:center">
        <div style="font-family:'JetBrains Mono',monospace;font-size:1.6rem;color:#c4972a;letter-spacing:-.02em">${collection.length}</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:.54rem;color:#5a5752;letter-spacing:.1em;text-transform:uppercase;margin-top:4px">Cards entered</div>
      </div>
      <div style="background:#0d0d0b;border:1px solid rgba(196,151,42,.15);padding:20px 18px;text-align:center">
        <div style="font-family:'JetBrains Mono',monospace;font-size:1.6rem;color:#c4972a;letter-spacing:-.02em">${recognized.length}</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:.54rem;color:#5a5752;letter-spacing:.1em;text-transform:uppercase;margin-top:4px">In model</div>
      </div>
      <div style="background:#0d0d0b;border:1px solid rgba(196,151,42,.15);padding:20px 18px;text-align:center">
        <div style="font-family:'JetBrains Mono',monospace;font-size:1.6rem;color:#c4972a;letter-spacing:-.02em">${avgScore}</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:.54rem;color:#5a5752;letter-spacing:.1em;text-transform:uppercase;margin-top:4px">Avg model score</div>
      </div>
      <div style="background:#0d0d0b;border:1px solid rgba(196,151,42,.15);padding:20px 18px;text-align:center">
        <div style="font-family:'JetBrains Mono',monospace;font-size:1.6rem;color:#c4972a;letter-spacing:-.02em">${recs.length}</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:.54rem;color:#5a5752;letter-spacing:.1em;text-transform:uppercase;margin-top:4px">Recommendations</div>
      </div>
    </div>`;

  // Recognized collection
  if (recognized.length > 0) {
    html += `<div style="font-family:'JetBrains Mono',monospace;font-size:.62rem;color:#c4972a;letter-spacing:.16em;text-transform:uppercase;display:flex;align-items:center;gap:12px;margin-bottom:20px">
      <span style="width:20px;height:1px;background:#c4972a;display:inline-block"></span>
      Your collection — ${recognized.length} cards mapped
      <span style="flex:1;height:1px;background:rgba(196,151,42,.15);display:inline-block"></span>
    </div>
    <div style="display:flex;flex-direction:column;gap:2px;margin-bottom:48px">
      ${recognized.map(c => renderCollectionCard(c)).join('')}
    </div>`;
  }

  // Unrecognized
  if (unrecognized.length > 0) {
    html += `<div style="background:#0d0d0b;border:1px solid rgba(90,87,82,.2);padding:20px 24px;margin-bottom:48px">
      <div style="font-family:'JetBrains Mono',monospace;font-size:.58rem;color:#5a5752;letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px">Not in current model universe (${unrecognized.length})</div>
      ${unrecognized.map(c => `<div style="font-family:'JetBrains Mono',monospace;font-size:.65rem;color:#5a5752;padding:4px 0">${c.raw}</div>`).join('')}
      <div style="font-family:'JetBrains Mono',monospace;font-size:.58rem;color:#5a5752;margin-top:10px;padding-top:10px;border-top:1px solid rgba(90,87,82,.15)">These cards aren't in the model yet. The model covers 28 assets — submit feedback below to help expand it.</div>
    </div>`;
  }

  // Recommendations
  if (upgrades.length > 0) {
    html += `<div style="font-family:'JetBrains Mono',monospace;font-size:.62rem;color:#7eb8c4;letter-spacing:.16em;text-transform:uppercase;display:flex;align-items:center;gap:12px;margin-bottom:20px">
      <span style="width:20px;height:1px;background:#7eb8c4;display:inline-block"></span>
      Upgrade paths — ${upgrades.length}
      <span style="flex:1;height:1px;background:rgba(126,184,196,.12);display:inline-block"></span>
    </div>
    <div style="margin-bottom:48px">${upgrades.map(r => renderRecCard(r)).join('')}</div>`;
  }

  if (gaps.length > 0) {
    html += `<div style="font-family:'JetBrains Mono',monospace;font-size:.62rem;color:#4caf50;letter-spacing:.16em;text-transform:uppercase;display:flex;align-items:center;gap:12px;margin-bottom:20px">
      <span style="width:20px;height:1px;background:#4caf50;display:inline-block"></span>
      Buy signal gaps — ${gaps.length}
      <span style="flex:1;height:1px;background:rgba(76,175,80,.12);display:inline-block"></span>
    </div>
    <div style="margin-bottom:48px">${gaps.map(r => renderRecCard(r)).join('')}</div>`;
  }

  if (setComps.length > 0) {
    html += `<div style="font-family:'JetBrains Mono',monospace;font-size:.62rem;color:#c4972a;letter-spacing:.16em;text-transform:uppercase;display:flex;align-items:center;gap:12px;margin-bottom:20px">
      <span style="width:20px;height:1px;background:#c4972a;display:inline-block"></span>
      Set completion — ${setComps.length}
      <span style="flex:1;height:1px;background:rgba(196,151,42,.12);display:inline-block"></span>
    </div>
    <div style="margin-bottom:48px">${setComps.map(r => renderRecCard(r)).join('')}</div>`;
  }

  if (divers.length > 0) {
    html += `<div style="font-family:'JetBrains Mono',monospace;font-size:.62rem;color:#9b6bc4;letter-spacing:.16em;text-transform:uppercase;display:flex;align-items:center;gap:12px;margin-bottom:20px">
      <span style="width:20px;height:1px;background:#9b6bc4;display:inline-block"></span>
      Diversification
      <span style="flex:1;height:1px;background:rgba(155,107,196,.12);display:inline-block"></span>
    </div>
    <div style="margin-bottom:48px">${divers.map(r => renderRecCard(r)).join('')}</div>`;
  }

  if (watches.length > 0) {
    html += `<div style="font-family:'JetBrains Mono',monospace;font-size:.62rem;color:#5a5752;letter-spacing:.16em;text-transform:uppercase;display:flex;align-items:center;gap:12px;margin-bottom:20px">
      <span style="width:20px;height:1px;background:#5a5752;display:inline-block"></span>
      Watch list additions
      <span style="flex:1;height:1px;background:rgba(90,87,82,.2);display:inline-block"></span>
    </div>
    <div style="margin-bottom:48px">${watches.map(r => renderRecCard(r)).join('')}</div>`;
  }

  // Training feedback section
  html += `
    <div style="background:#0d0d0b;border:1px solid rgba(196,151,42,.15);border-left:3px solid #c4972a;padding:32px 36px;margin-bottom:48px">
      <div style="font-family:'JetBrains Mono',monospace;font-size:.58rem;color:#c4972a;letter-spacing:.14em;text-transform:uppercase;margin-bottom:14px">Help train the model</div>
      <div style="font-family:'JetBrains Mono',monospace;font-size:.68rem;color:#a09c94;line-height:1.8;margin-bottom:18px">
        Cards not in the model universe, collection patterns, and what people actually own are all useful signals. 
        If you own cards that weren't recognized, or if the recommendations miss the mark, let us know.
      </div>
      <div style="display:flex;gap:2px">
        <textarea id="feedback-input" placeholder="Cards I own that aren't in the model: &#10;Feedback on recommendations: &#10;Sets I'm focused on collecting: " 
          style="flex:1;background:#121210;border:1px solid rgba(196,151,42,.12);padding:14px 16px;font-family:'JetBrains Mono',monospace;font-size:.68rem;color:#e8e6e1;line-height:1.7;outline:none;resize:vertical;min-height:100px"></textarea>
      </div>
      <button onclick="submitFeedback()" style="margin-top:2px;width:100%;background:rgba(196,151,42,.08);border:1px solid rgba(196,151,42,.15);padding:12px;font-family:'JetBrains Mono',monospace;font-size:.65rem;color:#c4972a;letter-spacing:.1em;text-transform:uppercase;cursor:pointer" 
        onmouseover="this.style.background='rgba(196,151,42,.15)'" onmouseout="this.style.background='rgba(196,151,42,.08)'">
        Submit feedback →
      </button>
      <div id="feedback-thanks" style="display:none;font-family:'JetBrains Mono',monospace;font-size:.65rem;color:#4caf50;margin-top:10px;text-align:center">Thank you — this helps improve the model.</div>
    </div>

    <!-- Start over -->
    <button onclick="resetAdvisor()" style="width:100%;background:transparent;border:1px solid rgba(196,151,42,.15);padding:16px;font-family:'JetBrains Mono',monospace;font-size:.65rem;color:#5a5752;letter-spacing:.1em;text-transform:uppercase;cursor:pointer"
      onmouseover="this.style.borderColor='rgba(196,151,42,.35)';this.style.color='#c4972a'" 
      onmouseout="this.style.borderColor='rgba(196,151,42,.15)';this.style.color='#5a5752'">
      ← Analyze a different collection
    </button>`;

  const resultsEl = document.getElementById('results-section');
  resultsEl.innerHTML = html;
  resultsEl.style.display = 'block';
  document.getElementById('input-section').style.display = 'none';

  setTimeout(() => resultsEl.scrollIntoView({behavior:'smooth', block:'start'}), 100);
}

function submitFeedback() {
  const feedback = document.getElementById('feedback-input').value.trim();
  if (!feedback) return;
  // Log feedback — training signal for model expansion
  console.log('VESSEL_ADVISOR_FEEDBACK', {
    timestamp: new Date().toISOString(),
    feedback,
  });
  document.getElementById('feedback-input').value = '';
  document.getElementById('feedback-thanks').style.display = 'block';
}

function resetAdvisor() {
  document.getElementById('results-section').style.display = 'none';
  document.getElementById('results-section').innerHTML = '';
  document.getElementById('input-section').style.display = 'block';
  window.scrollTo({top: 0, behavior: 'smooth'});
}
</script>
