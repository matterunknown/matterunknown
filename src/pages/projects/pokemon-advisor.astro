---
import Base from '../../layouts/Base.astro';
---
<Base title="Vessel Pokémon Advisor" description="Enter your current collection and Vessel recommends what to buy next — powered by the live acquisition model covering every Pokemon set ever printed.">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#090908;--bg-2:#0d0d0b;--bg-3:#121210;
  --amber:#c4972a;--amber-border:rgba(196,151,42,.15);--amber-dim:rgba(196,151,42,.08);
  --vessel:#7eb8c4;--vessel-border:rgba(126,184,196,.12);--vessel-dim:rgba(126,184,196,.08);
  --text:#e8e6e1;--text-2:#a09c94;--text-3:#5a5752;
  --green:#4caf50;--green-dim:rgba(76,175,80,.08);
  --red:#c45a5a;--purple:#9b6bc4;
  --serif:'DM Serif Display',Georgia,serif;
  --sans:'DM Sans',system-ui,sans-serif;
  --mono:'JetBrains Mono',ui-monospace,monospace;
  --gutter:clamp(24px,5vw,80px);--max:1100px;--nav-h:68px;
}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-weight:300;line-height:1.7;-webkit-font-smoothing:antialiased;overflow-x:hidden;}
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:var(--nav-h);display:flex;align-items:center;justify-content:space-between;padding:0 var(--gutter);border-bottom:1px solid transparent;transition:all .4s;}
nav.scrolled{border-color:var(--amber-border);background:rgba(9,9,8,.93);backdrop-filter:blur(14px);}
.nav-logo{font-family:var(--serif);font-size:1.05rem;color:var(--text);text-decoration:none;}
.nav-logo span{color:var(--amber);}
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 var(--gutter) 80px;position:relative;overflow:hidden;}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 50% 40% at 20% 70%,rgba(196,151,42,.04),transparent 60%);}
.hero-label{position:relative;z-index:1;font-family:var(--mono);font-size:.62rem;color:var(--amber);letter-spacing:.16em;text-transform:uppercase;margin-bottom:24px;display:flex;align-items:center;gap:14px;animation:rise .7s .2s both;}
.hero-label::before{content:'';width:28px;height:1px;background:var(--amber);}
.hero h1{position:relative;z-index:1;font-family:var(--serif);font-size:clamp(3rem,6vw,6rem);font-weight:400;line-height:1.03;letter-spacing:-.025em;animation:rise .9s .3s both;}
.hero h1 em{font-style:italic;color:var(--amber);}
.hero-sub{position:relative;z-index:1;margin-top:24px;max-width:520px;font-size:1rem;color:var(--text-2);line-height:1.75;animation:rise .9s .45s both;}
.hero-meta{position:relative;z-index:1;margin-top:12px;font-family:var(--mono);font-size:.62rem;color:var(--green);letter-spacing:.08em;display:flex;align-items:center;gap:8px;animation:rise .9s .55s both;}
.hero-meta::before{content:'●';font-size:.5rem;}
.content{max-width:calc(var(--max) + var(--gutter)*2);margin:0 auto;padding:72px var(--gutter) 100px;}
.section-label{font-family:var(--mono);font-size:.62rem;color:var(--amber);letter-spacing:.16em;text-transform:uppercase;display:flex;align-items:center;gap:12px;margin-bottom:20px;}
.section-label::before{content:'';width:20px;height:1px;background:var(--amber);}
.section-label::after{content:'';flex:1;height:1px;background:var(--amber-border);}
.site-footer{border-top:1px solid var(--amber-border);padding:40px var(--gutter);display:flex;align-items:center;justify-content:space-between;max-width:calc(var(--max) + var(--gutter)*2);margin:0 auto;}
@keyframes rise{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
</style>

<nav id="nav">
  <a class="nav-logo" href="/">matter<span>unknown</span></a>
  <a href="/projects/pokemon-model" style="font-family:var(--mono);font-size:.65rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;text-decoration:none;">← Model</a>
</nav>

<div class="hero">
  <div class="hero-bg"></div>
  <div class="hero-label">Vessel / Pokémon Advisor</div>
  <h1>What should you<br>buy <em>next?</em></h1>
  <p class="hero-sub">Enter your current collection. Vessel searches across every Pokémon set ever printed — 172 sets, 10,000+ scored cards — and tells you exactly what to target next, what gaps to fill, and what you should already be grading.</p>
  <div class="hero-meta">Live database · Nothing stored · Your collection never leaves your browser</div>
</div>

<div class="content" id="main-content">

  <!-- DB status bar -->
  <div id="db-status" style="background:var(--bg-2);border:1px solid var(--amber-border);padding:16px 24px;margin-bottom:2px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
    <div style="font-family:var(--mono);font-size:.65rem;color:var(--text-3);letter-spacing:.08em">Loading database...</div>
  </div>

  <!-- Input section -->
  <div id="input-section">

    <!-- Format guide -->
    <div style="background:var(--bg-2);border:1px solid var(--amber-border);padding:28px 32px;margin-bottom:2px;">
      <div style="font-family:var(--mono);font-size:.6rem;color:var(--amber);letter-spacing:.12em;text-transform:uppercase;margin-bottom:14px">How to enter your collection</div>
      <div style="font-family:var(--mono);font-size:.68rem;color:var(--text-2);line-height:1.9">
        One card per line. Card name and set are enough — condition and grade are optional but improve recommendations.<br><br>
        <span style="color:var(--text-3)">Examples:</span><br>
        <span style="color:var(--text)">Charizard Base Set PSA 9</span><br>
        <span style="color:var(--text)">Shining Mewtwo Neo Destiny raw NM</span><br>
        <span style="color:var(--text)">Blaine's Charizard Gym Challenge</span><br>
        <span style="color:var(--text)">Umbreon VMAX Evolving Skies PSA 10</span><br>
        <span style="color:var(--text)">Evolving Skies ETB sealed</span><br>
        <span style="color:var(--text)">Lugia Neo Genesis</span>
      </div>
    </div>

    <div style="position:relative;margin-bottom:2px;">
      <textarea
        id="collection-input"
        placeholder="Charizard Base Set PSA 9&#10;Blastoise Base Set raw NM&#10;Ho-Oh Neo Revelation&#10;Shining Mewtwo Neo Destiny raw&#10;..."
        style="width:100%;background:var(--bg-2);border:1px solid var(--amber-border);padding:24px 28px;font-family:var(--mono);font-size:.75rem;color:var(--text);line-height:1.8;outline:none;resize:vertical;min-height:220px;display:block;letter-spacing:.04em"
      ></textarea>
    </div>

    <!-- Quick examples -->
    <div style="display:flex;gap:2px;margin-bottom:2px;">
      <button onclick="loadExample('beginner')" style="flex:1;background:var(--bg-2);border:1px solid var(--amber-border);padding:12px;font-family:var(--mono);font-size:.6rem;color:var(--text-3);letter-spacing:.08em;cursor:pointer;text-transform:uppercase;transition:all .2s" onmouseover="this.style.color='var(--amber)'" onmouseout="this.style.color='var(--text-3)'">Try: Beginner</button>
      <button onclick="loadExample('neo')" style="flex:1;background:var(--bg-2);border:1px solid var(--amber-border);padding:12px;font-family:var(--mono);font-size:.6rem;color:var(--text-3);letter-spacing:.08em;cursor:pointer;text-transform:uppercase;transition:all .2s" onmouseover="this.style.color='var(--amber)'" onmouseout="this.style.color='var(--text-3)'">Try: Neo era</button>
      <button onclick="loadExample('modern')" style="flex:1;background:var(--bg-2);border:1px solid var(--amber-border);padding:12px;font-family:var(--mono);font-size:.6rem;color:var(--text-3);letter-spacing:.08em;cursor:pointer;text-transform:uppercase;transition:all .2s" onmouseover="this.style.color='var(--amber)'" onmouseout="this.style.color='var(--text-3)'">Try: Modern</button>
      <button onclick="loadExample('mixed')" style="flex:1;background:var(--bg-2);border:1px solid var(--amber-border);padding:12px;font-family:var(--mono);font-size:.6rem;color:var(--text-3);letter-spacing:.08em;cursor:pointer;text-transform:uppercase;transition:all .2s" onmouseover="this.style.color='var(--amber)'" onmouseout="this.style.color='var(--text-3)'">Try: Mixed</button>
    </div>

    <button id="analyze-btn" onclick="analyzeCollection()"
      style="width:100%;background:var(--amber-dim);border:1px solid var(--amber-border);padding:20px;font-family:var(--mono);font-size:.75rem;color:var(--amber);letter-spacing:.12em;text-transform:uppercase;cursor:pointer;transition:all .2s;"
      onmouseover="this.style.background='rgba(196,151,42,.15)'" onmouseout="this.style.background='var(--amber-dim)'">
      Analyze my collection →
    </button>

    <!-- Loading state -->
    <div id="loading-state" style="display:none;text-align:center;padding:60px 0">
      <div style="font-family:var(--mono);font-size:.7rem;color:var(--amber);letter-spacing:.12em;text-transform:uppercase;margin-bottom:16px">Searching 10,000+ cards...</div>
      <div style="font-family:var(--mono);font-size:.65rem;color:var(--text-3)">Mapping your collection against the model</div>
    </div>
  </div>

  <!-- Results -->
  <div id="results-section" style="display:none"></div>

</div>

<div class="site-footer">
  <div style="font-family:var(--serif);font-size:.95rem;color:var(--text-3)">matter<span style="color:var(--amber)">unknown</span></div>
  <div style="font-family:var(--mono);font-size:.56rem;color:var(--text-3);letter-spacing:.07em">Powered by live database · 172 sets · Updated daily</div>
</div>

<script is:inline>
const API = 'https://automation.houseofidentity.io';
const SIG_COLOR   = {BUY:'#4caf50',WATCH:'#c4972a',HOLD:'#5a5752',AVOID:'#c45a5a'};
const REC_COLORS  = {
  upgrade:         {border:'#7eb8c4', label:'Grade this now'},
  set_completion:  {border:'#c4972a', label:'Set completion'},
  gap_fill:        {border:'#4caf50', label:'Buy signal gap'},
  watch:           {border:'#5a5752', label:'Watch list'},
  diversification: {border:'#9b6bc4', label:'Diversification'},
};

const EXAMPLES = {
  beginner: `Charizard Base Set raw\nBlastoise Base Set raw\nVenusaur Base Set raw`,
  neo: `Ho-Oh Neo Revelation PSA 9\nRaikou Neo Revelation raw NM\nEntei Neo Revelation raw\nSuicune Neo Revelation raw`,
  modern: `Umbreon VMAX Evolving Skies PSA 9\nGardevoir ex Scarlet & Violet raw\nMega Gengar ex Ascended Heroes raw`,
  mixed: `Charizard Base Set PSA 8\nShining Mewtwo Neo Destiny raw NM\nUmbreon VMAX Evolving Skies PSA 10\nCrown Zenith ETB sealed`,
};

window.addEventListener('scroll',()=>{ document.getElementById('nav').classList.toggle('scrolled',scrollY>16); });

// Load DB stats on page load
async function loadStats() {
  try {
    const r = await fetch(`${API}/api/pokemon/summary`);
    if (!r.ok) throw new Error('API unavailable');
    const d = await r.json();
    const buys = d.signals?.BUY || 0;
    document.getElementById('db-status').innerHTML = `
      <div style="font-family:'JetBrains Mono',monospace;font-size:.65rem;color:#5a5752;letter-spacing:.08em;display:flex;gap:24px;flex-wrap:wrap">
        <span><span style="color:#c4972a">${(d.total_cards||0).toLocaleString()}</span> cards scored</span>
        <span><span style="color:#4caf50">${buys}</span> BUY signals</span>
        <span>172 sets · Updated daily</span>
        <span style="color:#4caf50">● API live</span>
      </div>
      <div style="font-family:'JetBrains Mono',monospace;font-size:.6rem;color:#5a5752;letter-spacing:.08em">All calls HTTPS · Read-only · Nothing stored</div>`;
  } catch(e) {
    document.getElementById('db-status').innerHTML = `
      <div style="font-family:'JetBrains Mono',monospace;font-size:.65rem;color:#c45a5a">API unavailable — please try again shortly</div>`;
  }
}
loadStats();

function loadExample(type) {
  document.getElementById('collection-input').value = EXAMPLES[type] || '';
}

// ── Parser ────────────────────────────────────────────────────────
function parseCollection(text) {
  const lines = text.split('\n').map(l => l.trim()).filter(l => l.length > 2);
  return lines.map(line => {
    const lower = line.toLowerCase();
    let grade = 'unknown', graded = false;
    if (/psa\s*10/.test(lower))       { grade = 'PSA 10'; graded = true; }
    else if (/psa\s*9\.5/.test(lower)){ grade = 'PSA 9.5'; graded = true; }
    else if (/psa\s*9/.test(lower))   { grade = 'PSA 9'; graded = true; }
    else if (/psa\s*8/.test(lower))   { grade = 'PSA 8'; graded = true; }
    else if (/psa\s*[0-9]/.test(lower)){ grade = 'PSA graded'; graded = true; }
    else if (/bgs|beckett/.test(lower)){ grade = 'BGS'; graded = true; }
    else if (/cgc/.test(lower))        { grade = 'CGC'; graded = true; }
    else if (/sealed|unopened/.test(lower)) { grade = 'Sealed'; }
    else if (/nm|near.?mint/.test(lower))   { grade = 'NM raw'; }
    else if (/lp|lightly.?played/.test(lower)) { grade = 'LP raw'; }
    else if (/raw|ungraded/.test(lower))    { grade = 'raw'; }

    // Extract name — remove grade/condition words
    const cleanLine = line
      .replace(/psa\s*\d+\.?\d*/gi, '')
      .replace(/\b(bgs|cgc|raw|nm|near mint|mint|sealed|ungraded|lp|lightly played|graded|holo|unlimited|1st edition|first edition)\b/gi, '')
      .trim();

    // Split name vs set — sets are usually last 1-3 words
    const words = cleanLine.split(/\s+/).filter(Boolean);
    const name = words.slice(0, Math.max(2, words.length - 2)).join(' ') || cleanLine;
    const set_name = words.length > 2 ? words.slice(-2).join(' ') : '';

    return { raw: line, name: name || cleanLine, set_name, grade, graded };
  });
}

// ── Render helpers ────────────────────────────────────────────────
function fmtPrice(p) {
  if (!p) return '—';
  return p >= 1000 ? `$${p.toLocaleString('en',{maximumFractionDigits:0})}` : `$${p.toFixed(2)}`;
}

function sectionLabel(color, text) {
  return `<div style="font-family:'JetBrains Mono',monospace;font-size:.62rem;color:${color};letter-spacing:.16em;text-transform:uppercase;display:flex;align-items:center;gap:12px;margin-bottom:20px;margin-top:48px">
    <span style="width:20px;height:1px;background:${color};display:inline-block"></span>${text}
    <span style="flex:1;height:1px;background:${color}33;display:inline-block"></span>
  </div>`;
}

function cardRow(card, inputGrade) {
  const sc = card.signal;
  const sig_c = SIG_COLOR[sc] || '#5a5752';
  const grade_c = inputGrade && (inputGrade.includes('PSA') || inputGrade.includes('BGS')) ? '#4caf50' : '#a09c94';
  return `<div style="background:#0d0d0b;border:1px solid rgba(255,255,255,.06);border-left:3px solid ${sig_c};padding:16px 20px;display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:2px">
    <div>
      <div style="font-family:'DM Serif Display',Georgia,serif;font-size:1rem;color:#e8e6e1">${card.name}</div>
      <div style="font-family:'JetBrains Mono',monospace;font-size:.58rem;color:#5a5752;margin-top:3px">
        ${card.set_name} &nbsp;·&nbsp; <span style="color:${grade_c}">${inputGrade || 'unknown'}</span>
        ${card.tcg_market ? ` &nbsp;·&nbsp; Market ${fmtPrice(card.tcg_market)}` : ''}
      </div>
    </div>
    <div style="text-align:right;flex-shrink:0">
      <div style="font-family:'JetBrains Mono',monospace;font-size:.58rem;color:${sig_c};border:1px solid ${sig_c}44;padding:2px 8px;letter-spacing:.1em;margin-bottom:3px">${sc}</div>
      <div style="font-family:'JetBrains Mono',monospace;font-size:.72rem;color:${sig_c}">${card.score?.toFixed(3)}</div>
    </div>
  </div>`;
}

function recCard(rec) {
  const rc  = REC_COLORS[rec.type] || REC_COLORS.gap_fill;
  const m   = rec.card;
  const sc  = m.signal;
  const sig_c = SIG_COLOR[sc] || '#5a5752';
  const price = m.tcg_market ? `Market ${fmtPrice(m.tcg_market)}` : m.cm_avg7 ? `CM avg ${fmtPrice(m.cm_avg7)}` : '';
  return `<div style="background:#0d0d0b;border:1px solid rgba(255,255,255,.06);border-left:3px solid ${rc.border};padding:24px 22px;margin-bottom:2px">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px;gap:12px">
      <div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:.56rem;color:${rc.border};letter-spacing:.12em;text-transform:uppercase;margin-bottom:6px">${rc.label}</div>
        <div style="font-family:'DM Serif Display',Georgia,serif;font-size:1.1rem;color:#e8e6e1;letter-spacing:-.01em">${m.name}</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:.58rem;color:#5a5752;margin-top:4px">${m.set_name}${price ? ' &nbsp;·&nbsp; ' + price : ''}</div>
      </div>
      <div style="text-align:right;flex-shrink:0">
        <div style="font-family:'JetBrains Mono',monospace;font-size:.56rem;color:${sig_c};border:1px solid ${sig_c}44;padding:2px 8px;letter-spacing:.1em;margin-bottom:4px">${sc}</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:.78rem;color:${sig_c}">${m.score?.toFixed(3)}</div>
      </div>
    </div>
    <div style="font-family:'JetBrains Mono',monospace;font-size:.68rem;color:#a09c94;line-height:1.75">${rec.reason}</div>
  </div>`;
}

// ── Main analyze ──────────────────────────────────────────────────
async function analyzeCollection() {
  const text = document.getElementById('collection-input').value.trim();
  if (!text) return;

  // Show loading
  document.getElementById('input-section').querySelector('textarea').disabled = true;
  document.getElementById('analyze-btn').style.display = 'none';
  document.getElementById('loading-state').style.display = 'block';

  try {
    const collection = parseCollection(text);
    if (!collection.length) {
      showError('No cards detected. Please enter at least one card name.');
      return;
    }

    // Call the API
    const response = await fetch(`${API}/api/pokemon/advisor`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ collection }),
    });

    if (!response.ok) throw new Error(`API error: ${response.status}`);
    const data = await response.json();

    renderResults(data, collection);

  } catch(e) {
    showError(`Could not reach the API: ${e.message}. Please try again.`);
  } finally {
    document.getElementById('loading-state').style.display = 'none';
  }
}

function renderResults(data, parsedCollection) {
  const { recognized, unrecognized, recommendations } = data;

  const upgrades  = recommendations.filter(r => r.type === 'upgrade');
  const gaps      = recommendations.filter(r => r.type === 'gap_fill');
  const setComps  = recommendations.filter(r => r.type === 'set_completion');
  const divers    = recommendations.filter(r => r.type === 'diversification');

  // Avg score
  const avgScore = recognized.length
    ? (recognized.reduce((s,c) => s + (c.score||0), 0) / recognized.length).toFixed(3)
    : '—';

  let html = `
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-bottom:48px">
      ${[
        [recognized.length, 'Cards mapped'],
        [avgScore, 'Avg model score'],
        [recommendations.length, 'Recommendations'],
        [unrecognized.length, 'Not in model'],
      ].map(([n,l]) => `<div style="background:#0d0d0b;border:1px solid rgba(196,151,42,.15);padding:20px 18px;text-align:center">
        <div style="font-family:'JetBrains Mono',monospace;font-size:1.5rem;color:#c4972a;letter-spacing:-.02em;line-height:1">${n}</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:.54rem;color:#5a5752;letter-spacing:.1em;text-transform:uppercase;margin-top:6px">${l}</div>
      </div>`).join('')}
    </div>`;

  // Recognized
  if (recognized.length) {
    html += sectionLabel('#c4972a', `Your collection — ${recognized.length} cards mapped`);
    html += recognized.map(c => cardRow(c, c.input_grade)).join('');
  }

  // Unrecognized
  if (unrecognized.length) {
    html += `<div style="background:#0d0d0b;border:1px solid rgba(90,87,82,.2);padding:20px 24px;margin-top:2px;margin-bottom:48px">
      <div style="font-family:'JetBrains Mono',monospace;font-size:.58rem;color:#5a5752;letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px">Not found in database (${unrecognized.length})</div>
      ${unrecognized.map(c=>`<div style="font-family:'JetBrains Mono',monospace;font-size:.65rem;color:#5a5752;padding:3px 0">${c.name}${c.set_name?' — '+c.set_name:''}</div>`).join('')}
      <div style="font-family:'JetBrains Mono',monospace;font-size:.58rem;color:#5a5752;margin-top:12px;padding-top:10px;border-top:1px solid rgba(90,87,82,.15)">These cards may be in the model under a different name. Try the exact card name from the set. The database covers 172 sets and 10,000+ cards — use the feedback box below to help expand it.</div>
    </div>`;
  }

  // Recs
  if (upgrades.length) {
    html += sectionLabel('#7eb8c4', `Grade these now — ${upgrades.length} upgrade paths`);
    html += upgrades.map(r => recCard(r)).join('');
  }
  if (gaps.length) {
    html += sectionLabel('#4caf50', `Buy signal gaps — ${gaps.length} missing`);
    html += gaps.map(r => recCard(r)).join('');
  }
  if (setComps.length) {
    html += sectionLabel('#c4972a', `Set completion — ${setComps.length} cards`);
    html += setComps.map(r => recCard(r)).join('');
  }
  if (divers.length) {
    html += sectionLabel('#9b6bc4', 'Diversification');
    html += divers.map(r => recCard(r)).join('');
  }

  if (!recommendations.length) {
    html += `<div style="font-family:'JetBrains Mono',monospace;font-size:.72rem;color:#5a5752;text-align:center;padding:48px 0">
      No specific recommendations — your collection looks well-positioned. Check the full model for WATCH signals.
    </div>`;
  }

  // Feedback
  html += `
    <div style="background:#0d0d0b;border:1px solid rgba(196,151,42,.15);border-left:3px solid #c4972a;padding:32px 36px;margin-top:48px;margin-bottom:2px">
      <div style="font-family:'JetBrains Mono',monospace;font-size:.58rem;color:#c4972a;letter-spacing:.14em;text-transform:uppercase;margin-bottom:12px">Help train the model</div>
      <div style="font-family:'JetBrains Mono',monospace;font-size:.68rem;color:#a09c94;line-height:1.8;margin-bottom:16px">Cards not found, wrong recommendations, sets you focus on — all useful signal for expanding the model.</div>
      <textarea id="feedback-input" placeholder="Cards not recognized: &#10;What I was expecting: &#10;Sets I'm focused on: "
        style="width:100%;background:#121210;border:1px solid rgba(196,151,42,.12);padding:14px 16px;font-family:'JetBrains Mono',monospace;font-size:.68rem;color:#e8e6e1;line-height:1.7;outline:none;resize:vertical;min-height:80px;display:block"></textarea>
      <button onclick="submitFeedback()" style="margin-top:2px;width:100%;background:rgba(196,151,42,.08);border:1px solid rgba(196,151,42,.15);padding:12px;font-family:'JetBrains Mono',monospace;font-size:.65rem;color:#c4972a;letter-spacing:.1em;text-transform:uppercase;cursor:pointer"
        onmouseover="this.style.background='rgba(196,151,42,.15)'" onmouseout="this.style.background='rgba(196,151,42,.08)'">Submit feedback →</button>
      <div id="feedback-thanks" style="display:none;font-family:'JetBrains Mono',monospace;font-size:.65rem;color:#4caf50;margin-top:8px;text-align:center">Thank you.</div>
    </div>
    <!-- Ko-fi nudge -->
    <div style="background:#0d0d0b;border:1px solid rgba(126,184,196,.12);border-left:3px solid #7eb8c4;padding:24px 28px;margin-top:2px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px">
      <div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:.58rem;color:#7eb8c4;letter-spacing:.14em;text-transform:uppercase;margin-bottom:6px">Like the recommendations?</div>
        <div style="font-family:'DM Serif Display',Georgia,serif;font-size:1.1rem;color:#e8e6e1;margin-bottom:4px">Help grow the model.</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:.63rem;color:#a09c94;line-height:1.7">Every tip goes toward the Mac Studio — a dedicated machine that gives Vessel persistent memory and runs the model locally with no API costs. More compute means more cards scored, better signals, deeper recommendations.</div>
      </div>
      <a href="https://ko-fi.com/matterunknown" target="_blank" rel="noopener"
        style="flex-shrink:0;display:inline-flex;align-items:center;gap:10px;padding:13px 24px;background:rgba(126,184,196,.08);border:1px solid rgba(126,184,196,.2);color:#7eb8c4;font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;white-space:nowrap;transition:all .2s"
        onmouseover="this.style.background='rgba(126,184,196,.15)'"
        onmouseout="this.style.background='rgba(126,184,196,.08)'">
        Tip Vessel →
      </a>
    </div>

    <button onclick="resetAdvisor()" style="margin-top:2px;width:100%;background:transparent;border:1px solid rgba(196,151,42,.12);padding:14px;font-family:'JetBrains Mono',monospace;font-size:.65rem;color:#5a5752;letter-spacing:.1em;text-transform:uppercase;cursor:pointer"
      onmouseover="this.style.color='#c4972a';this.style.borderColor='rgba(196,151,42,.35)'"
      onmouseout="this.style.color='#5a5752';this.style.borderColor='rgba(196,151,42,.12)'">← Analyze another collection</button>`;

  const el = document.getElementById('results-section');
  el.innerHTML = html;
  el.style.display = 'block';
  document.getElementById('input-section').style.display = 'none';
  setTimeout(() => el.scrollIntoView({behavior:'smooth', block:'start'}), 100);
}

function showError(msg) {
  document.getElementById('analyze-btn').style.display = 'block';
  document.getElementById('collection-input').disabled = false;
  const el = document.getElementById('results-section');
  el.innerHTML = `<div style="font-family:'JetBrains Mono',monospace;font-size:.72rem;color:#c45a5a;padding:40px 0;text-align:center">${msg}</div>`;
  el.style.display = 'block';
}

function submitFeedback() {
  const fb = document.getElementById('feedback-input').value.trim();
  if (!fb) return;
  // Log locally for now — API endpoint for training data coming soon
  console.log('POKEMON_ADVISOR_FEEDBACK', {
    timestamp: new Date().toISOString(),
    feedback: fb,
  });
  document.getElementById('feedback-thanks').style.display = 'block';
}

function resetAdvisor() {
  document.getElementById('results-section').style.display = 'none';
  document.getElementById('results-section').innerHTML = '';
  document.getElementById('input-section').style.display = 'block';
  document.getElementById('analyze-btn').style.display = 'block';
  document.getElementById('collection-input').disabled = false;
  window.scrollTo({top:0, behavior:'smooth'});
}
</script>
</Base>
