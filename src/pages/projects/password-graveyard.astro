---
import Base from '../../layouts/Base.astro';
---
<Base title="The Password Graveyard" description="Every password has a death date. Enter yours and find out when it died — and what killed it. 100% client-side. Nothing is ever sent anywhere.">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#090908;--bg-2:#0d0d0b;--bg-3:#121210;
  --amber:#c4972a;--amber-border:rgba(196,151,42,.15);--amber-dim:rgba(196,151,42,.08);
  --vessel:#7eb8c4;--vessel-border:rgba(126,184,196,.12);
  --text:#e8e6e1;--text-2:#a09c94;--text-3:#5a5752;
  --red:#c45a5a;--red-dim:rgba(196,90,90,.08);--red-border:rgba(196,90,90,.2);
  --green:#4caf50;--green-dim:rgba(76,175,80,.08);
  --serif:'DM Serif Display',Georgia,serif;
  --sans:'DM Sans',system-ui,sans-serif;
  --mono:'JetBrains Mono',ui-monospace,monospace;
  --gutter:clamp(24px,5vw,80px);--max:1160px;--nav-h:68px;
}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-weight:300;line-height:1.7;-webkit-font-smoothing:antialiased;overflow-x:hidden;}
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:var(--nav-h);display:flex;align-items:center;justify-content:space-between;padding:0 var(--gutter);border-bottom:1px solid transparent;transition:all .4s;}
nav.scrolled{border-color:var(--red-border);background:rgba(9,9,8,.93);backdrop-filter:blur(14px);}
.nav-logo{font-family:var(--serif);font-size:1.05rem;color:var(--text);text-decoration:none;}
.nav-logo span{color:var(--amber);}

.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 var(--gutter) 80px;position:relative;overflow:hidden;}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 50% 80%,rgba(196,90,90,.05),transparent 60%);}
.hero-label{position:relative;z-index:1;font-family:var(--mono);font-size:.62rem;color:var(--red);letter-spacing:.16em;text-transform:uppercase;margin-bottom:24px;display:flex;align-items:center;gap:14px;animation:rise .7s .2s both;}
.hero-label::before{content:'';width:28px;height:1px;background:var(--red);}
.hero h1{position:relative;z-index:1;font-family:var(--serif);font-size:clamp(3rem,6.5vw,6.5rem);font-weight:400;line-height:1.03;letter-spacing:-.025em;animation:rise .9s .3s both;}
.hero h1 em{font-style:italic;color:var(--red);}
.hero-sub{position:relative;z-index:1;margin-top:24px;max-width:540px;font-size:1.05rem;color:var(--text-2);line-height:1.75;animation:rise .9s .45s both;}
.privacy-tag{position:relative;z-index:1;margin-top:16px;font-family:var(--mono);font-size:.62rem;color:var(--green);letter-spacing:.08em;display:flex;align-items:center;gap:8px;animation:rise .9s .55s both;}
.privacy-tag::before{content:'●';font-size:.5rem;}

.section{max-width:calc(var(--max) + var(--gutter)*2);margin:0 auto;padding:80px var(--gutter) 100px;}

.input-wrap{position:relative;margin-bottom:3px;}
.pw-input{width:100%;background:var(--bg-2);border:1px solid var(--red-border);padding:22px 160px 22px 28px;font-family:var(--mono);font-size:1.1rem;color:var(--text);letter-spacing:.15em;outline:none;transition:border-color .2s;}
.pw-input:focus{border-color:var(--red);}
.pw-input::placeholder{color:var(--text-3);letter-spacing:.06em;font-size:.9rem;}
.pw-input.visible{-webkit-text-security:none;letter-spacing:.12em;}
.pw-input:not(.visible){-webkit-text-security:disc;}
.btn-row{position:absolute;right:0;top:0;bottom:0;display:flex;}
.toggle-btn{padding:0 16px;background:transparent;border:none;border-left:1px solid var(--red-border);color:var(--text-3);font-family:var(--mono);font-size:.58rem;letter-spacing:.08em;cursor:pointer;transition:color .2s;}
.toggle-btn:hover{color:var(--text);}
.analyze-btn{padding:0 24px;background:var(--red-dim);border:none;border-left:1px solid var(--red-border);color:var(--red);font-family:var(--mono);font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;transition:all .2s;}
.analyze-btn:hover{background:rgba(196,90,90,.15);}

.strength-bar{height:3px;background:var(--bg-3);margin-bottom:48px;}
.strength-fill{height:100%;width:0%;transition:width .4s ease,background .4s ease;border-radius:0;}
.strength-label{font-family:var(--mono);font-size:.6rem;color:var(--text-3);letter-spacing:.1em;margin-top:6px;}

/* Graveyard */
.graveyard{display:none;animation:rise .6s both;}
.graveyard.show{display:block;}

.tombstone-wrap{display:flex;justify-content:center;margin-bottom:60px;}
.tombstone{background:var(--bg-2);border:1px solid var(--red-border);border-top:4px solid var(--red);padding:52px 64px 64px;text-align:center;max-width:440px;width:100%;position:relative;}
.tombstone::after{content:'';position:absolute;bottom:-18px;left:10%;right:10%;height:18px;background:var(--bg-3);border:1px solid var(--red-border);border-top:none;}
.rip{font-family:var(--mono);font-size:.6rem;color:var(--red);letter-spacing:.24em;text-transform:uppercase;margin-bottom:24px;opacity:.7;}
.pw-tombstone{font-family:var(--mono);font-size:1.3rem;color:var(--text);letter-spacing:.1em;margin-bottom:6px;word-break:break-all;}
.born-died{font-family:var(--serif);font-size:.95rem;color:var(--text-3);font-style:italic;margin-bottom:24px;line-height:1.6;}
.cause-of-death{font-family:var(--mono);font-size:.62rem;color:var(--red);letter-spacing:.1em;text-transform:uppercase;border:1px solid var(--red-border);padding:8px 18px;display:inline-block;}

.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:var(--red-border);margin-bottom:2px;}
.stat-cell{background:var(--bg-2);padding:28px 20px;text-align:center;}
.stat-num{font-family:var(--mono);font-size:1.8rem;letter-spacing:-.02em;line-height:1;}
.stat-num.danger{color:var(--red);}
.stat-num.warn{color:var(--amber);}
.stat-num.safe{color:var(--green);}
.stat-label{font-family:var(--mono);font-size:.56rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;margin-top:6px;}

.forensics{background:var(--bg-2);border:1px solid var(--red-border);border-left:3px solid var(--red);padding:36px 40px;margin-bottom:2px;}
.f-label{font-family:var(--mono);font-size:.58rem;color:var(--red);letter-spacing:.14em;text-transform:uppercase;margin-bottom:16px;}
.f-report{font-family:var(--mono);font-size:.73rem;color:var(--text-2);line-height:1.9;}
.f-report strong{color:var(--text);}

.patterns-wrap{background:var(--bg-2);border:1px solid var(--red-border);padding:28px;margin-bottom:60px;}
.pattern-row{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid rgba(196,90,90,.06);}
.pattern-row:last-child{border-bottom:none;}
.p-name{font-family:var(--mono);font-size:.65rem;color:var(--text-2);letter-spacing:.06em;}
.p-val{font-family:var(--mono);font-size:.62rem;letter-spacing:.08em;text-transform:uppercase;}
.p-val.fail{color:var(--red);}
.p-val.pass{color:var(--green);}
.p-val.warn{color:var(--amber);}

.site-footer{border-top:1px solid var(--red-border);padding:44px var(--gutter);display:flex;align-items:center;justify-content:space-between;max-width:calc(var(--max) + var(--gutter)*2);margin:0 auto;}
.footer-logo{font-family:var(--serif);font-size:.95rem;color:var(--text-3);}
.footer-logo span{color:var(--amber);}
.footer-copy{font-family:var(--mono);font-size:.58rem;color:var(--text-3);letter-spacing:.07em;}
@keyframes rise{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:700px){.stats-grid{grid-template-columns:1fr 1fr;}.tombstone{padding:36px 32px 48px;}}
</style>

<nav id="nav">
  <a class="nav-logo" href="/">matter<span>unknown</span></a>
  <a href="/projects" style="font-family:var(--mono);font-size:.65rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;text-decoration:none;">← Projects</a>
</nav>

<div class="hero">
  <div class="hero-bg"></div>
  <div class="hero-label">Experiment No. 2 / Interactive</div>
  <h1>Every password<br>has a <em>death date.</em></h1>
  <p class="hero-sub">Enter any password and Vessel will tell you exactly when it died, what killed it, how long it would take to crack, and which breach databases it probably lived in. A forensic report for the string you've been reusing since 2014.</p>
  <div class="privacy-tag">100% client-side. Your password never leaves your browser. Ever.</div>
</div>

<div class="section">
  <div class="input-wrap">
    <input class="pw-input" id="pw-input" type="password" placeholder="Enter any password — it never leaves this page" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" />
    <div class="btn-row">
      <button class="toggle-btn" id="toggle-btn" onclick="toggleVis()">Show</button>
      <button class="analyze-btn" onclick="analyze()">Analyze →</button>
    </div>
  </div>
  <div class="strength-bar"><div class="strength-fill" id="strength-fill"></div></div>
  <div class="strength-label" id="strength-label"></div>

  <div class="graveyard" id="graveyard">

    <div class="tombstone-wrap">
      <div class="tombstone">
        <div class="rip">R . I . P</div>
        <div class="pw-tombstone" id="tomb-pw"></div>
        <div class="born-died" id="tomb-dates"></div>
        <div class="cause-of-death" id="tomb-cause"></div>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-cell"><div class="stat-num" id="stat-crack-time">—</div><div class="stat-label">Time to crack</div></div>
      <div class="stat-cell"><div class="stat-num" id="stat-entropy">—</div><div class="stat-label">Bits of entropy</div></div>
      <div class="stat-cell"><div class="stat-num" id="stat-score">—</div><div class="stat-label">Strength score</div></div>
    </div>

    <div class="forensics" style="margin-top:2px;">
      <div class="f-label">Vessel's forensic report</div>
      <div class="f-report" id="forensic-report"></div>
    </div>

    <div class="patterns-wrap" style="margin-top:2px;">
      <div id="patterns-list"></div>
    </div>

  </div>
</div>

<div class="site-footer">
  <div class="footer-logo">matter<span>unknown</span></div>
  <div class="footer-copy">Experiment No. 2 — nothing is transmitted. Ever.</div>
</div>

<script is:inline>
window.addEventListener('scroll',()=>{ document.getElementById('nav').classList.toggle('scrolled',scrollY>16); });

let visible = false;
function toggleVis() {
  visible = !visible;
  const inp = document.getElementById('pw-input');
  inp.type = visible ? 'text' : 'password';
  document.getElementById('toggle-btn').textContent = visible ? 'Hide' : 'Show';
}

// Live strength meter
document.getElementById('pw-input').addEventListener('input', function() {
  const pw = this.value;
  if (!pw) {
    document.getElementById('strength-fill').style.width = '0%';
    document.getElementById('strength-label').textContent = '';
    return;
  }
  const score = getScore(pw);
  const pct = Math.min(100, score * 14);
  const color = score < 3 ? '#c45a5a' : score < 5 ? '#c4972a' : score < 7 ? '#7eb8c4' : '#4caf50';
  const label = score < 3 ? 'Very weak' : score < 5 ? 'Weak' : score < 7 ? 'Moderate' : 'Strong';
  document.getElementById('strength-fill').style.cssText = `width:${pct}%;background:${color};`;
  document.getElementById('strength-label').textContent = label;
});

document.getElementById('pw-input').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') analyze();
});

function getScore(pw) {
  let score = 0;
  if (pw.length >= 8) score++;
  if (pw.length >= 12) score++;
  if (pw.length >= 16) score++;
  if (pw.length >= 20) score++;
  if (/[a-z]/.test(pw)) score++;
  if (/[A-Z]/.test(pw)) score++;
  if (/[0-9]/.test(pw)) score++;
  if (/[^a-zA-Z0-9]/.test(pw)) score++;
  // Penalize common patterns
  if (/^[a-zA-Z]+\d{1,4}$/.test(pw)) score -= 2;
  if (/(.)\1{2,}/.test(pw)) score -= 1;
  if (/123|234|345|456|567|678|789|890/.test(pw)) score -= 1;
  if (/password|qwerty|letmein|welcome|admin|login/i.test(pw)) score -= 3;
  return Math.max(0, score);
}

function getEntropy(pw) {
  let charsetSize = 0;
  if (/[a-z]/.test(pw)) charsetSize += 26;
  if (/[A-Z]/.test(pw)) charsetSize += 26;
  if (/[0-9]/.test(pw)) charsetSize += 10;
  if (/[^a-zA-Z0-9]/.test(pw)) charsetSize += 32;
  return Math.round(pw.length * Math.log2(Math.max(charsetSize, 1)));
}

function getCrackTime(entropy) {
  // Assumes 10 billion guesses/second (GPU cluster)
  const guesses = Math.pow(2, entropy);
  const seconds = guesses / 10000000000;
  if (seconds < 1) return ['< 1 second', 'danger'];
  if (seconds < 60) return [Math.round(seconds) + ' seconds', 'danger'];
  if (seconds < 3600) return [Math.round(seconds/60) + ' minutes', 'danger'];
  if (seconds < 86400) return [Math.round(seconds/3600) + ' hours', 'warn'];
  if (seconds < 2592000) return [Math.round(seconds/86400) + ' days', 'warn'];
  if (seconds < 31536000) return [Math.round(seconds/2592000) + ' months', 'warn'];
  if (seconds < 31536000000) return [Math.round(seconds/31536000) + ' years', 'safe'];
  return ['centuries', 'safe'];
}

function getDeathDate(pw) {
  // Estimate when this password was likely first used / compromised
  const common2010 = /password|123456|qwerty|letmein|monkey|dragon|master|sunshine|princess|welcome/i;
  const common2015 = /iloveyou|football|login|admin|starwars|batman|superman|charlie|donald|baseball/i;
  const common2020 = /password1|abc123|111111|666666|123123|1234qwer/i;

  if (common2010.test(pw)) return ['circa 2011', 'In the Adobe breach of 2013. Probably before that.'];
  if (common2015.test(pw)) return ['circa 2015', 'In multiple breach databases. Likely LinkedIn 2016.'];
  if (common2020.test(pw)) return ['circa 2019', 'Pattern-matched in credential stuffing lists by 2020.'];
  if (pw.length < 6) return ['circa 2008', 'Too short to have survived any modern authentication system.'];
  if (pw.length < 8) return ['circa 2012', 'Failed minimum length requirements years ago.'];
  if (/(.)\1{3,}/.test(pw)) return ['circa 2010', 'Repetition patterns were the first to be dictionary-attacked.'];
  if (/^[a-zA-Z]+\d{1,4}$/.test(pw)) return ['circa 2014', 'Word+number pattern. First to fall in rule-based attacks.'];
  return ['unknown', 'Status unclear — analyze the patterns below.'];
}

function analyze() {
  const pw = document.getElementById('pw-input').value;
  if (!pw || pw.length < 1) return;

  const score = getScore(pw);
  const entropy = getEntropy(pw);
  const [crackTime, crackClass] = getCrackTime(entropy);
  const [deathDate, deathNote] = getDeathDate(pw);

  // Tombstone
  document.getElementById('tomb-pw').textContent = visible ? pw : '•'.repeat(Math.min(pw.length, 20));
  document.getElementById('tomb-dates').textContent = `Born: unknown  ·  Died: ${deathDate}`;

  const causes = [];
  if (pw.length < 8) causes.push('TOO SHORT');
  else if (/password|123456|qwerty|letmein|admin|login/i.test(pw)) causes.push('COMMON PASSWORD');
  else if (/^[a-zA-Z]+\d{1,4}$/.test(pw)) causes.push('PREDICTABLE PATTERN');
  else if (!/[^a-zA-Z0-9]/.test(pw)) causes.push('NO SPECIAL CHARACTERS');
  else if (entropy < 40) causes.push('LOW ENTROPY');
  else causes.push('SURVIVED — FOR NOW');
  document.getElementById('tomb-cause').textContent = causes[0];

  // Stats
  const crackEl = document.getElementById('stat-crack-time');
  crackEl.textContent = crackTime;
  crackEl.className = 'stat-num ' + crackClass;
  document.getElementById('stat-entropy').textContent = entropy + ' bits';
  document.getElementById('stat-entropy').className = 'stat-num ' + (entropy < 30 ? 'danger' : entropy < 50 ? 'warn' : 'safe');
  const scoreEl = document.getElementById('stat-score');
  scoreEl.textContent = score + ' / 8';
  scoreEl.className = 'stat-num ' + (score < 3 ? 'danger' : score < 6 ? 'warn' : 'safe');

  // Forensic report
  const reports = [];
  reports.push(`<strong>Length: ${pw.length} characters.</strong> ${pw.length < 8 ? 'Below the minimum threshold for any serious authentication system. This was never safe.' : pw.length < 12 ? 'Marginally acceptable in 2015. Insufficient now.' : pw.length < 16 ? 'Adequate length. Strength depends on complexity.' : 'Good length. Length is the most important factor.'}`);

  if (/password|123456|qwerty|letmein|admin|login|welcome|dragon|monkey|master/i.test(pw)) {
    reports.push(`<strong>Common password detected.</strong> This exact string — or a trivial variant — appears in every credential stuffing list in circulation. It has been tried against every major authentication endpoint thousands of times per day since at least 2013. ${deathNote}`);
  }

  if (/^[a-zA-Z]+\d{1,4}$/.test(pw)) {
    reports.push(`<strong>Word + number pattern.</strong> The most common password construction in breach databases. "Name followed by year of birth" and "word followed by 1-4 digits" are the first patterns any rule-based attack applies. This pattern provides almost no additional security over the base word.`);
  }

  if (/(.)\1{3,}/.test(pw)) {
    reports.push(`<strong>Character repetition detected.</strong> Strings with three or more repeated characters are trivially pattern-matched and appear in basic dictionary attack wordlists.`);
  }

  if (!/[^a-zA-Z0-9]/.test(pw) && pw.length >= 8) {
    reports.push(`<strong>No special characters.</strong> Without symbols, the character space is limited to 62 characters. Adding even one symbol increases resistance to brute-force by orders of magnitude.`);
  }

  if (entropy >= 60 && score >= 7) {
    reports.push(`<strong>This password is genuinely strong.</strong> At ${entropy} bits of entropy with a crack time of ${crackTime}, it would survive most attack scenarios. The question is whether you're reusing it.`);
  }

  reports.push(`<strong>The real risk isn't brute force.</strong> It's credential stuffing — attackers taking passwords from one breach and trying them everywhere. A password can be complex and still be compromised if it appeared in any of the 14+ billion credential pairs now circulating in breach databases.`);

  document.getElementById('forensic-report').innerHTML = reports.join('<br><br>');

  // Pattern checks
  const patterns = [
    ['Minimum length (8+)', pw.length >= 8, pw.length >= 8 ? 'pass' : 'fail'],
    ['Strong length (16+)', pw.length >= 16, pw.length >= 16 ? 'pass' : pw.length >= 8 ? 'warn' : 'fail'],
    ['Uppercase letters', /[A-Z]/.test(pw), /[A-Z]/.test(pw) ? 'pass' : 'fail'],
    ['Lowercase letters', /[a-z]/.test(pw), /[a-z]/.test(pw) ? 'pass' : 'fail'],
    ['Numbers', /[0-9]/.test(pw), /[0-9]/.test(pw) ? 'pass' : 'fail'],
    ['Special characters', /[^a-zA-Z0-9]/.test(pw), /[^a-zA-Z0-9]/.test(pw) ? 'pass' : 'fail'],
    ['Not a common password', !/password|123456|qwerty|letmein|admin|login|welcome/i.test(pw), !/password|123456|qwerty|letmein|admin|login|welcome/i.test(pw) ? 'pass' : 'fail'],
    ['No predictable patterns', !/^[a-zA-Z]+\d{1,4}$/.test(pw) && !/(.)\1{3,}/.test(pw), !/^[a-zA-Z]+\d{1,4}$/.test(pw) && !/(.)\1{3,}/.test(pw) ? 'pass' : 'fail'],
    ['Entropy > 50 bits', entropy >= 50, entropy >= 50 ? 'pass' : entropy >= 35 ? 'warn' : 'fail'],
  ];

  const patHtml = patterns.map(([name, , cls]) =>
    `<div class="pattern-row"><div class="p-name">${name}</div><div class="p-val ${cls}">${cls === 'pass' ? '✓ Pass' : cls === 'warn' ? '⚠ Marginal' : '✗ Fail'}</div></div>`
  ).join('');
  document.getElementById('patterns-list').innerHTML = patHtml;

  // Show graveyard
  document.getElementById('graveyard').classList.add('show');
  setTimeout(() => {
    document.getElementById('graveyard').scrollIntoView({behavior:'smooth', block:'start'});
  }, 100);
}
</script>
</Base>
