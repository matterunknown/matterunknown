---
import Base from '../../layouts/Base.astro';
---
<Base title="Vessel Crypto Model" description="A data-driven crypto acquisition model. Price signals, market structure, on-chain quality. 21 assets scored. Updated daily.">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#090908;--bg-2:#0d0d0b;--bg-3:#121210;
  --amber:#c4972a;--amber-border:rgba(196,151,42,.15);
  --vessel:#7eb8c4;--vessel-border:rgba(126,184,196,.12);--vessel-dim:rgba(126,184,196,.08);
  --text:#e8e6e1;--text-2:#a09c94;--text-3:#5a5752;
  --green:#4caf50;--red:#c45a5a;
  --serif:'DM Serif Display',Georgia,serif;
  --sans:'DM Sans',system-ui,sans-serif;
  --mono:'JetBrains Mono',ui-monospace,monospace;
  --gutter:clamp(24px,5vw,80px);--max:1100px;--nav-h:68px;
}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-weight:300;line-height:1.7;-webkit-font-smoothing:antialiased;overflow-x:hidden;}
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:var(--nav-h);display:flex;align-items:center;justify-content:space-between;padding:0 var(--gutter);border-bottom:1px solid transparent;transition:all .4s;}
nav.scrolled{border-color:var(--vessel-border);background:rgba(9,9,8,.93);backdrop-filter:blur(14px);}
.nav-logo{font-family:var(--serif);font-size:1.05rem;color:var(--text);text-decoration:none;}
.nav-logo span{color:var(--amber);}
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 var(--gutter) 80px;position:relative;overflow:hidden;}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 80% 70%,rgba(196,151,42,.04),transparent 60%),radial-gradient(ellipse 40% 30% at 20% 30%,rgba(126,184,196,.03),transparent 50%);}
.hero-label{position:relative;z-index:1;font-family:var(--mono);font-size:.62rem;color:var(--amber);letter-spacing:.16em;text-transform:uppercase;margin-bottom:24px;display:flex;align-items:center;gap:14px;animation:rise .7s .2s both;}
.hero-label::before{content:'';width:28px;height:1px;background:var(--amber);}
.hero h1{position:relative;z-index:1;font-family:var(--serif);font-size:clamp(3rem,6vw,6rem);font-weight:400;line-height:1.03;letter-spacing:-.025em;animation:rise .9s .3s both;}
.hero h1 em{font-style:italic;color:var(--amber);}
.hero-sub{position:relative;z-index:1;margin-top:24px;max-width:520px;font-size:1rem;color:var(--text-2);line-height:1.75;animation:rise .9s .45s both;}
.stats{position:relative;z-index:1;margin-top:48px;display:flex;gap:2px;flex-wrap:wrap;animation:rise .9s .6s both;}
.stat{background:var(--bg-2);border:1px solid var(--vessel-border);padding:18px 24px;}
.stat-num{font-family:var(--mono);font-size:1.4rem;color:var(--vessel);letter-spacing:-.02em;line-height:1;}
.stat-label{font-family:var(--mono);font-size:.54rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;margin-top:4px;}
.content{max-width:calc(var(--max) + var(--gutter)*2);margin:0 auto;padding:60px var(--gutter) 100px;}
.vessel-note{border-left:3px solid var(--amber);background:rgba(196,151,42,.04);border:1px solid var(--amber-border);border-left:3px solid var(--amber);padding:32px 36px;margin-bottom:48px;}
.vn-label{font-family:var(--mono);font-size:.58rem;color:var(--amber);letter-spacing:.14em;text-transform:uppercase;margin-bottom:14px;}
.vessel-note p{font-family:var(--serif);font-size:1rem;font-style:italic;color:var(--text-2);line-height:1.8;margin-bottom:10px;}
.vessel-note p:last-child{margin-bottom:0;}
.vessel-note p em{color:var(--amber);font-style:normal;}
.log-section{margin-bottom:48px;}
.log-toggle{width:100%;background:var(--bg-2);border:1px solid var(--amber-border);padding:14px 20px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;font-family:var(--mono);font-size:.6rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;transition:all .2s;}
.log-toggle:hover{border-color:var(--amber);color:var(--amber);}
.log-toggle-arrow{transition:transform .3s;font-size:.8rem;}
.log-toggle.open .log-toggle-arrow{transform:rotate(180deg);}
.log-entries{display:none;border:1px solid var(--amber-border);border-top:none;}
.log-entries.open{display:block;}
.log-entry{padding:20px 24px;border-bottom:1px solid var(--amber-border);}
.log-entry:last-child{border-bottom:none;}
.log-entry-label{font-family:var(--mono);font-size:.55rem;color:var(--amber);letter-spacing:.12em;text-transform:uppercase;margin-bottom:10px;}
.log-entry p{font-family:var(--serif);font-size:.88rem;font-style:italic;color:var(--text-3);line-height:1.75;margin-bottom:8px;}
.log-entry p:last-child{margin-bottom:0;}
.log-entry p em{color:var(--text-2);font-style:normal;}
.method{display:grid;grid-template-columns:1fr 1fr 1fr;gap:2px;margin-top:52px;margin-bottom:20px;}
.mc{background:var(--bg-2);border:1px solid var(--vessel-border);padding:24px 20px;}
.mc-label{font-family:var(--mono);font-size:.56rem;color:var(--vessel);letter-spacing:.12em;text-transform:uppercase;margin-bottom:6px;}
.mc-val{font-family:var(--mono);font-size:.95rem;color:var(--text);letter-spacing:-.01em;margin-bottom:6px;}
.mc-desc{font-family:var(--mono);font-size:.63rem;color:var(--text-3);line-height:1.65;}
.legend{display:flex;gap:20px;flex-wrap:wrap;margin-bottom:8px;}
.li{display:flex;align-items:center;gap:7px;font-family:var(--mono);font-size:.6rem;color:var(--text-3);letter-spacing:.07em;}
.ld{width:8px;height:8px;border-radius:50%;}
.site-footer{border-top:1px solid var(--vessel-border);padding:40px var(--gutter);display:flex;align-items:center;justify-content:space-between;max-width:calc(var(--max) + var(--gutter)*2);margin:0 auto;}
.footer-logo{font-family:var(--serif);font-size:.95rem;color:var(--text-3);}
.footer-logo span{color:var(--amber);}
.footer-copy{font-family:var(--mono);font-size:.56rem;color:var(--text-3);letter-spacing:.07em;}
@keyframes rise{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:800px){.stats{flex-direction:column;}.method{grid-template-columns:1fr;}}
</style>

<nav id="nav">
  <a class="nav-logo" href="/">matter<span>unknown</span></a>
  <a href="/projects" style="font-family:var(--mono);font-size:.65rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;text-decoration:none;">← Projects</a>
</nav>

<div class="hero">
  <div class="hero-bg"></div>
  <div class="hero-label">Vessel Crypto Model — v1</div>
  <h1>Crypto scored<br>by <em>data,</em><br>not narrative.</h1>
  <p class="hero-sub">21 assets across 5 categories. Three scoring layers: price signals, market structure (Fear & Greed, BTC dominance, ATH distance), and asset quality. Special focus on the AI/data infrastructure tier — the intersection of crypto and the thing matterunknown is actually obsessed with.</p>
