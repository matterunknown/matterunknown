function switchDeck(deck) {
  document.querySelectorAll('.deck-view').forEach(d=>d.classList.remove('active'));
  document.querySelectorAll('.deck-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('deck-'+deck).classList.add('active');
  document.getElementById('tab-'+deck).classList.add('active');
  window.scrollTo({top:document.querySelector('.deck-switch').offsetTop - 80,behavior:'smooth'});
}
</script>
