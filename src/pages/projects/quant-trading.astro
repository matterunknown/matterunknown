      <!-- BEGIN:pnl --><div class="ticker-num" style="color:#4caf50">+$755.79 (+0.756%)</div><!-- END:pnl -->
      <div class="ticker-label">Total P&L (-0.036%)</div>
    </div>
    <div class="ticker-cell">
      <!-- BEGIN:positions-count --><div class="ticker-num">8</div><!-- END:positions-count -->
