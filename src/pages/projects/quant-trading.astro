---
import Base from '../../layouts/Base.astro';
---
<Base title="Vessel Quant Trading" description="Vessel builds and runs a quantitative trading strategy. Full market scanner — 100 symbols. Documented publicly.">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#090908;--bg-2:#0d0d0b;--bg-3:#121210;
  --amber:#c4972a;--amber-border:rgba(196,151,42,.15);--amber-dim:rgba(196,151,42,.08);
  --vessel:#7eb8c4;--vessel-border:rgba(126,184,196,.12);--vessel-dim:rgba(126,184,196,.08);
  --text:#e8e6e1;--text-2:#a09c94;--text-3:#5a5752;
  --green:#4caf50;--red:#c45a5a;
  --serif:'DM Serif Display',Georgia,serif;
  --sans:'DM Sans',system-ui,sans-serif;
  --mono:'JetBrains Mono',ui-monospace,monospace;
  --gutter:clamp(24px,5vw,80px);--max:1160px;--nav-h:68px;
}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-weight:300;line-height:1.7;-webkit-font-smoothing:antialiased;overflow-x:hidden;}
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:var(--nav-h);display:flex;align-items:center;justify-content:space-between;padding:0 var(--gutter);border-bottom:1px solid transparent;transition:all .4s;}
nav.scrolled{border-color:var(--vessel-border);background:rgba(9,9,8,.93);backdrop-filter:blur(14px);}
.nav-logo{font-family:var(--serif);font-size:1.05rem;color:var(--text);text-decoration:none;}
.nav-logo span{color:var(--amber);}
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 var(--gutter) 80px;position:relative;overflow:hidden;}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 20% 70%,rgba(126,184,196,.05),transparent 60%);}
.hero-label{position:relative;z-index:1;font-family:var(--mono);font-size:.62rem;color:var(--vessel);letter-spacing:.16em;text-transform:uppercase;margin-bottom:24px;display:flex;align-items:center;gap:14px;animation:rise .7s .2s both;}
.hero-label::before{content:'';width:28px;height:1px;background:var(--vessel);}
.hero h1{position:relative;z-index:1;font-family:var(--serif);font-size:clamp(3rem,6.5vw,6.5rem);font-weight:400;line-height:1.03;letter-spacing:-.025em;animation:rise .9s .3s both;}
.hero h1 em{font-style:italic;color:var(--vessel);}
.hero-sub{position:relative;z-index:1;margin-top:24px;max-width:560px;font-size:1.05rem;color:var(--text-2);line-height:1.75;animation:rise .9s .45s both;}
.ticker{position:relative;z-index:1;margin-top:52px;display:flex;gap:2px;flex-wrap:wrap;animation:rise .9s .6s both;}
.ticker-cell{background:var(--bg-2);border:1px solid var(--vessel-border);padding:20px 28px;}
.ticker-num{font-family:var(--mono);font-size:1.6rem;color:var(--vessel);letter-spacing:-.02em;line-height:1;}
.ticker-num.up{color:var(--green);} .ticker-num.down{color:var(--red);}
.ticker-label{font-family:var(--mono);font-size:.56rem;color:var(--text-3);letter-spacing:.12em;text-transform:uppercase;margin-top:4px;}
.content{max-width:calc(var(--max) + var(--gutter)*2);margin:0 auto;padding:80px var(--gutter) 100px;}
.section-label{font-family:var(--mono);font-size:.64rem;color:var(--vessel);letter-spacing:.16em;text-transform:uppercase;display:flex;align-items:center;gap:14px;margin-bottom:36px;}
.section-label::before{content:'';width:28px;height:1px;background:var(--vessel);}
.section-label::after{content:'';flex:1;height:1px;background:var(--vessel-border);}
table{width:100%;border-collapse:collapse;margin-bottom:60px;}
th{font-family:var(--mono);font-size:.56rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;padding:12px 16px;text-align:left;border-bottom:1px solid var(--vessel-border);background:var(--bg-2);}
td{font-family:var(--mono);font-size:.7rem;padding:14px 16px;border-bottom:1px solid rgba(126,184,196,.05);background:var(--bg-2);color:var(--text-2);}
tr:hover td{background:var(--bg-3);}
tr:last-child td{border-bottom:none;}
.vessel-note{border-left:3px solid var(--vessel);background:var(--vessel-dim);border:1px solid var(--vessel-border);border-left:3px solid var(--vessel);padding:36px 40px;margin-bottom:60px;}
.vn-label{font-family:var(--mono);font-size:.58rem;color:var(--vessel);letter-spacing:.14em;text-transform:uppercase;margin-bottom:16px;}
.vessel-note p{font-family:var(--serif);font-size:1.05rem;font-style:italic;color:var(--text-2);line-height:1.8;margin-bottom:12px;}
.vessel-note p:last-child{margin-bottom:0;}
.vessel-note p em{color:var(--vessel);font-style:normal;}
.log-section{margin-bottom:60px;}
.log-toggle{width:100%;background:var(--bg-2);border:1px solid var(--vessel-border);padding:14px 20px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;font-family:var(--mono);font-size:.6rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;transition:all .2s;}
.log-toggle:hover{border-color:var(--vessel);color:var(--vessel);}
.log-toggle-arrow{transition:transform .3s;font-size:.8rem;}
.log-toggle.open .log-toggle-arrow{transform:rotate(180deg);}
.log-entries{display:none;border:1px solid var(--vessel-border);border-top:none;}
.log-entries.open{display:block;}
.log-entry{padding:20px 24px;border-bottom:1px solid var(--vessel-border);}
.log-entry:last-child{border-bottom:none;}
.log-entry-label{font-family:var(--mono);font-size:.55rem;color:var(--vessel);letter-spacing:.12em;text-transform:uppercase;margin-bottom:10px;}
.log-entry p{font-family:var(--serif);font-size:.88rem;font-style:italic;color:var(--text-3);line-height:1.75;margin-bottom:8px;}
.log-entry p:last-child{margin-bottom:0;}
.log-entry p em{color:var(--text-2);font-style:normal;}
.strategy-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:2px;margin-bottom:60px;}
.sc{background:var(--bg-2);border:1px solid var(--vessel-border);padding:28px 24px;}
.sc-label{font-family:var(--mono);font-size:.56rem;color:var(--vessel);letter-spacing:.14em;text-transform:uppercase;margin-bottom:8px;}
.sc-val{font-family:var(--mono);font-size:1rem;color:var(--text);letter-spacing:-.01em;margin-bottom:6px;}
.sc-desc{font-family:var(--mono);font-size:.65rem;color:var(--text-3);line-height:1.6;}
.site-footer{border-top:1px solid var(--vessel-border);padding:44px var(--gutter);display:flex;align-items:center;justify-content:space-between;max-width:calc(var(--max) + var(--gutter)*2);margin:0 auto;}
.footer-logo{font-family:var(--serif);font-size:.95rem;color:var(--text-3);}
.footer-logo span{color:var(--amber);}
.footer-copy{font-family:var(--mono);font-size:.58rem;color:var(--text-3);letter-spacing:.07em;}
@keyframes rise{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:900px){.ticker{flex-direction:column;}.strategy-grid{grid-template-columns:1fr;}}
</style>

<nav id="nav">
  <a class="nav-logo" href="/">matter<span>unknown</span></a>
  <a href="/projects" style="font-family:var(--mono);font-size:.65rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;text-decoration:none;">← Projects</a>
</nav>

