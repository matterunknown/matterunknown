---
import Base from '../../layouts/Base.astro';
---
<Base title="Your Digital Shadow" description="Answer 10 questions. Vessel reconstructs what data brokers, advertisers, and surveillance systems probably know about you right now.">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#090908;--bg-2:#0d0d0b;--bg-3:#121210;
  --amber:#c4972a;--amber-border:rgba(196,151,42,.15);--amber-dim:rgba(196,151,42,.08);
  --vessel:#7eb8c4;--vessel-border:rgba(126,184,196,.12);--vessel-dim:rgba(126,184,196,.08);
  --text:#e8e6e1;--text-2:#a09c94;--text-3:#5a5752;
  --red:#c45a5a;--red-dim:rgba(196,90,90,.08);--red-border:rgba(196,90,90,.2);
  --green:#4caf50;
  --serif:'DM Serif Display',Georgia,serif;
  --sans:'DM Sans',system-ui,sans-serif;
  --mono:'JetBrains Mono',ui-monospace,monospace;
  --gutter:clamp(24px,5vw,80px);--max:1160px;--nav-h:68px;
}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-weight:300;line-height:1.7;-webkit-font-smoothing:antialiased;overflow-x:hidden;}
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:var(--nav-h);display:flex;align-items:center;justify-content:space-between;padding:0 var(--gutter);border-bottom:1px solid transparent;transition:all .4s;}
nav.scrolled{border-color:var(--vessel-border);background:rgba(9,9,8,.93);backdrop-filter:blur(14px);}
.nav-logo{font-family:var(--serif);font-size:1.05rem;color:var(--text);text-decoration:none;}
.nav-logo span{color:var(--amber);}

.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 var(--gutter) 80px;position:relative;overflow:hidden;}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 30% 70%,rgba(126,184,196,.04),transparent 60%);}
.hero-label{position:relative;z-index:1;font-family:var(--mono);font-size:.62rem;color:var(--vessel);letter-spacing:.16em;text-transform:uppercase;margin-bottom:24px;display:flex;align-items:center;gap:14px;animation:rise .7s .2s both;}
.hero-label::before{content:'';width:28px;height:1px;background:var(--vessel);}
.hero h1{position:relative;z-index:1;font-family:var(--serif);font-size:clamp(3rem,6.5vw,6.5rem);font-weight:400;line-height:1.03;letter-spacing:-.025em;animation:rise .9s .3s both;}
.hero h1 em{font-style:italic;color:var(--vessel);}
.hero-sub{position:relative;z-index:1;margin-top:24px;max-width:560px;font-size:1.05rem;color:var(--text-2);line-height:1.75;animation:rise .9s .45s both;}
.privacy-tag{position:relative;z-index:1;margin-top:16px;font-family:var(--mono);font-size:.62rem;color:var(--green);letter-spacing:.08em;display:flex;align-items:center;gap:8px;animation:rise .9s .55s both;}
.privacy-tag::before{content:'●';font-size:.5rem;}

.section{max-width:calc(var(--max) + var(--gutter)*2);margin:0 auto;padding:80px var(--gutter) 100px;}

/* Progress */
.progress-bar{height:2px;background:var(--bg-3);margin-bottom:48px;}
.progress-fill{height:100%;background:var(--vessel);transition:width .4s ease;width:0%;}
.progress-label{font-family:var(--mono);font-size:.6rem;color:var(--text-3);letter-spacing:.1em;margin-top:6px;}

/* Questions */
.question-wrap{display:none;}
.question-wrap.active{display:block;animation:rise .5s both;}
.q-number{font-family:var(--mono);font-size:.6rem;color:var(--vessel);letter-spacing:.14em;text-transform:uppercase;margin-bottom:16px;}
.q-text{font-family:var(--serif);font-size:1.6rem;font-weight:400;letter-spacing:-.01em;margin-bottom:32px;line-height:1.3;}
.q-options{display:flex;flex-direction:column;gap:2px;}
.q-option{background:var(--bg-2);border:1px solid var(--vessel-border);padding:18px 24px;cursor:pointer;font-family:var(--mono);font-size:.75rem;color:var(--text-2);letter-spacing:.06em;transition:all .2s;display:flex;align-items:center;gap:14px;}
.q-option:hover{background:var(--vessel-dim);border-color:rgba(126,184,196,.28);color:var(--vessel);}
.q-option.selected{background:var(--vessel-dim);border-color:var(--vessel);color:var(--vessel);}
.q-option::before{content:'○';font-size:.7rem;opacity:.5;}
.q-option.selected::before{content:'●';opacity:1;}

/* Shadow result */
.shadow-result{display:none;animation:rise .6s both;}
.shadow-result.show{display:block;}

/* Shadow visualization */
.shadow-viz{display:flex;justify-content:center;margin-bottom:60px;}
.shadow-orb{width:220px;height:220px;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;border:1px solid var(--vessel-border);}
.shadow-score-num{font-family:var(--mono);font-size:3rem;color:var(--vessel);letter-spacing:-.04em;line-height:1;}
.shadow-score-label{font-family:var(--mono);font-size:.58rem;color:var(--text-3);letter-spacing:.12em;text-transform:uppercase;margin-top:8px;}
.shadow-grade{font-family:var(--serif);font-size:1rem;color:var(--text-2);font-style:italic;margin-top:4px;}

/* Data broker cards */
.broker-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:2px;margin-bottom:60px;}
.broker-card{background:var(--bg-2);border:1px solid var(--vessel-border);padding:24px 20px;}
.broker-name{font-family:var(--mono);font-size:.65rem;color:var(--vessel);letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px;}
.broker-data{font-family:var(--mono);font-size:.68rem;color:var(--text-2);line-height:1.8;}
.broker-data li{list-style:none;padding-left:0;margin-bottom:4px;}
.broker-data li::before{content:'→ ';color:var(--vessel);opacity:.6;}

/* Vessel analysis */
.vessel-analysis{background:var(--bg-2);border:1px solid var(--vessel-border);border-left:3px solid var(--vessel);padding:36px 40px;margin-bottom:60px;}
.va-label{font-family:var(--mono);font-size:.58rem;color:var(--vessel);letter-spacing:.14em;text-transform:uppercase;margin-bottom:16px;}
.va-text{font-family:var(--mono);font-size:.73rem;color:var(--text-2);line-height:1.9;}
.va-text strong{color:var(--text);}

.reset-btn{font-family:var(--mono);font-size:.68rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;background:transparent;border:1px solid var(--vessel-border);padding:12px 24px;cursor:pointer;transition:all .2s;}
.reset-btn:hover{border-color:var(--vessel);color:var(--vessel);}

.site-footer{border-top:1px solid var(--vessel-border);padding:44px var(--gutter);display:flex;align-items:center;justify-content:space-between;max-width:calc(var(--max) + var(--gutter)*2);margin:0 auto;}
.footer-logo{font-family:var(--serif);font-size:.95rem;color:var(--text-3);}
.footer-logo span{color:var(--amber);}
.footer-copy{font-family:var(--mono);font-size:.58rem;color:var(--text-3);letter-spacing:.07em;}
@keyframes rise{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:700px){.broker-grid{grid-template-columns:1fr;}.shadow-orb{width:180px;height:180px;}}
</style>

<nav id="nav">
  <a class="nav-logo" href="/">matter<span>unknown</span></a>
  <a href="/projects" style="font-family:var(--mono);font-size:.65rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;text-decoration:none;">← Projects</a>
</nav>

<div class="hero">
  <div class="hero-bg"></div>
  <div class="hero-label">Experiment No. 3 / Interactive</div>
  <h1>What does your<br><em>digital shadow</em><br>look like?</h1>
  <p class="hero-sub">Answer 10 questions about your online habits. Vessel reconstructs what data brokers, advertising networks, and surveillance systems probably know about you right now — not your actual data, but a probabilistic profile based on how these systems actually work.</p>
  <div class="privacy-tag">Nothing you enter is collected, stored, or transmitted. Vessel calculates everything locally.</div>
</div>

<div class="section">
  <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
  <div class="progress-label" id="progress-label">Question 1 of 10</div>

  <div id="questions-container"></div>

  <div class="shadow-result" id="shadow-result">
    <div class="shadow-viz">
      <div class="shadow-orb" id="shadow-orb">
        <div class="shadow-score-num" id="shadow-score">—</div>
        <div class="shadow-score-label">Exposure score</div>
        <div class="shadow-grade" id="shadow-grade">calculating...</div>
      </div>
    </div>

    <div class="broker-grid" id="broker-grid"></div>

    <div class="vessel-analysis">
      <div class="va-label">Vessel's assessment</div>
      <div class="va-text" id="vessel-assessment"></div>
    </div>

    <button class="reset-btn" onclick="resetShadow()">Start over</button>
  </div>
</div>

<div class="site-footer">
  <div class="footer-logo">matter<span>unknown</span></div>
  <div class="footer-copy">Experiment No. 3 — probabilistic reconstruction. Not your actual data.</div>
</div>

<script is:inline>
window.addEventListener('scroll',()=>{ document.getElementById('nav').classList.toggle('scrolled',scrollY>16); });

const QUESTIONS = [
  {
    id: 'smartphone',
    text: 'Do you carry a smartphone with location services enabled?',
    options: [
      {label: 'Yes, always on', value: 3},
      {label: 'Yes, but I limit location access', value: 2},
      {label: 'Yes, location completely disabled', value: 1},
      {label: 'No smartphone', value: 0},
    ]
  },
  {
    id: 'google',
    text: 'Do you use Google Search, Gmail, or Google Maps regularly?',
    options: [
      {label: 'All three, logged in', value: 3},
      {label: 'One or two of them', value: 2},
      {label: 'Occasionally, not logged in', value: 1},
      {label: 'None — I use alternatives', value: 0},
    ]
  },
  {
    id: 'social',
    text: 'How active are you on social media with your real identity?',
    options: [
      {label: 'Multiple platforms, real name, frequent posts', value: 3},
      {label: 'One or two platforms, occasional posts', value: 2},
      {label: 'Account exists but rarely active', value: 1},
      {label: 'No real-name social media presence', value: 0},
    ]
  },
  {
    id: 'shopping',
    text: 'How do you typically shop online?',
    options: [
      {label: 'Amazon Prime, saved cards, logged in always', value: 3},
      {label: 'Multiple retailers, logged-in accounts', value: 2},
      {label: 'Occasionally, prefer guest checkout', value: 1},
      {label: 'Rarely, cash or privacy-focused', value: 0},
    ]
  },
  {
    id: 'work',
    text: 'What does your professional online presence look like?',
    options: [
      {label: 'LinkedIn + public profile + work email public', value: 3},
      {label: 'LinkedIn exists, fairly detailed', value: 2},
      {label: 'Minimal LinkedIn, no other public work presence', value: 1},
      {label: 'No professional online presence', value: 0},
    ]
  },
  {
    id: 'streaming',
    text: 'Which streaming and subscription services do you use?',
    options: [
      {label: '5+ services with real name and payment info', value: 3},
      {label: '2-4 services', value: 2},
      {label: '1-2 services, privacy-conscious signups', value: 1},
      {label: 'None or self-hosted only', value: 0},
    ]
  },
  {
    id: 'browser',
    text: 'What browser and ad tracking settings do you use?',
    options: [
      {label: 'Chrome, no ad blockers, cookies accepted', value: 3},
      {label: 'Chrome or Firefox, some blocking', value: 2},
      {label: 'Firefox/Brave with significant blocking', value: 1},
      {label: 'Tor or maximum privacy configuration', value: 0},
    ]
  },
  {
    id: 'fitness',
    text: 'Do you use fitness or health tracking apps/devices?',
    options: [
      {label: 'Fitbit, Apple Watch, Garmin — synced to apps', value: 3},
      {label: 'Phone step counter or basic tracking', value: 2},
      {label: 'Minimal health app use', value: 1},
      {label: 'No health/fitness tracking', value: 0},
    ]
  },
  {
    id: 'financial',
    text: 'What is your banking and financial app usage?',
    options: [
      {label: 'Multiple banking apps, investment apps, Venmo/PayPal', value: 3},
      {label: 'Main bank app and one or two others', value: 2},
      {label: 'One bank app, minimal digital finance', value: 1},
      {label: 'Prefer cash, minimal digital financial presence', value: 0},
    ]
  },
  {
    id: 'email',
    text: 'How do you manage email and online accounts?',
    options: [
      {label: 'One Gmail for everything, same password patterns', value: 3},
      {label: 'A few emails, some password reuse', value: 2},
      {label: 'Separate emails, password manager', value: 1},
      {label: 'Privacy email (Proton etc), unique passwords everywhere', value: 0},
    ]
  }
];

let answers = {};
let currentQ = 0;

function buildQuestions() {
  const container = document.getElementById('questions-container');
  if(!container) return;
  container.innerHTML = '';

  QUESTIONS.forEach((q, i) => {
    const wrap = document.createElement('div');
    wrap.id = 'q-' + i;
    wrap.style.cssText = i === 0
      ? 'display:block;animation:rise .5s both'
      : 'display:none';

    // Question number
    const num = document.createElement('div');
    num.style.cssText = 'font-family:"JetBrains Mono",monospace;font-size:.6rem;color:#7eb8c4;letter-spacing:.14em;text-transform:uppercase;margin-bottom:16px';
    num.textContent = `Question ${i+1} of ${QUESTIONS.length}`;
    wrap.appendChild(num);

    // Question text
    const text = document.createElement('div');
    text.style.cssText = 'font-family:"DM Serif Display",Georgia,serif;font-size:1.5rem;font-weight:400;letter-spacing:-.01em;margin-bottom:32px;line-height:1.3;color:#e8e6e1';
    text.textContent = q.text;
    wrap.appendChild(text);

    // Options container
    const opts = document.createElement('div');
    opts.style.cssText = 'display:flex;flex-direction:column;gap:2px';

    q.options.forEach((opt, j) => {
      const btn = document.createElement('div');
      btn.id = `q${i}-opt${j}`;
      btn.style.cssText = 'background:#0d0d0b;border:1px solid rgba(126,184,196,.12);padding:18px 24px;cursor:pointer;font-family:"JetBrains Mono",monospace;font-size:.75rem;color:#a09c94;letter-spacing:.06em;transition:all .2s;display:flex;align-items:center;gap:14px';

      const dot = document.createElement('span');
      dot.style.cssText = 'font-size:.7rem;opacity:.5;flex-shrink:0';
      dot.textContent = '○';
      btn.appendChild(dot);

      const label = document.createElement('span');
      label.textContent = opt.label;
      btn.appendChild(label);

      btn.addEventListener('mouseenter', () => {
        if(!btn.dataset.selected) {
          btn.style.background = 'rgba(126,184,196,.06)';
          btn.style.borderColor = 'rgba(126,184,196,.28)';
          btn.style.color = '#7eb8c4';
        }
      });
      btn.addEventListener('mouseleave', () => {
        if(!btn.dataset.selected) {
          btn.style.background = '#0d0d0b';
          btn.style.borderColor = 'rgba(126,184,196,.12)';
          btn.style.color = '#a09c94';
        }
      });

      btn.addEventListener('click', () => selectOption(i, j, opt.value));
      opts.appendChild(btn);
    });

    wrap.appendChild(opts);
    container.appendChild(wrap);
  });
}

function selectOption(qIdx, optIdx, value) {
  // Deselect all options for this question
  QUESTIONS[qIdx].options.forEach((_, j) => {
    const el = document.getElementById(`q${qIdx}-opt${j}`);
    if(el) {
      el.style.background = '#0d0d0b';
      el.style.borderColor = 'rgba(126,184,196,.12)';
      el.style.color = '#a09c94';
      el.querySelector('span').textContent = '○';
      delete el.dataset.selected;
    }
  });
  // Select this one
  const sel = document.getElementById(`q${qIdx}-opt${optIdx}`);
  if(sel) {
    sel.style.background = 'rgba(126,184,196,.08)';
    sel.style.borderColor = '#7eb8c4';
    sel.style.color = '#7eb8c4';
    sel.querySelector('span').textContent = '●';
    sel.dataset.selected = '1';
  }
  answers[QUESTIONS[qIdx].id] = value;

  // Auto-advance after brief delay
  setTimeout(() => {
    if (qIdx < QUESTIONS.length - 1) {
      showQuestion(qIdx + 1);
    } else {
      showResult();
    }
  }, 400);
}

function showQuestion(idx) {
  const prev = document.getElementById('q-' + currentQ);
  if(prev) prev.style.display = 'none';
  currentQ = idx;
  const next = document.getElementById('q-' + idx);
  if(next) { next.style.display = 'block'; next.style.animation = 'rise .5s both'; }
  const pct = (idx / QUESTIONS.length) * 100;
  const pf = document.getElementById('progress-fill');
  if(pf) pf.style.width = pct + '%';
  const pl = document.getElementById('progress-label');
  if(pl) pl.textContent = `Question ${idx + 1} of ${QUESTIONS.length}`;
}

function showResult() {
  // Hide all questions
  QUESTIONS.forEach((_, i) => document.getElementById('q-' + i)?.classList.remove('active'));
  const pfEl = document.getElementById('progress-fill');
  if(pfEl) pfEl.style.width = '100%';
  document.getElementById('progress-label').textContent = 'Analysis complete';

  // Calculate total score (0-30)
  const total = Object.values(answers).reduce((a, b) => a + b, 0);
  const pct = Math.round((total / 30) * 100);

  // Score display
  const orbColor = pct > 70 ? '#c45a5a' : pct > 45 ? '#c4972a' : '#7eb8c4';
  const orb = document.getElementById('shadow-orb');
  orb.style.background = `radial-gradient(circle at center, ${orbColor}10, transparent 70%)`;
  orb.style.borderColor = orbColor + '40';
  document.getElementById('shadow-score').textContent = pct + '%';
  document.getElementById('shadow-score').style.color = orbColor;

  const grade = pct > 80 ? 'Extensive shadow' : pct > 60 ? 'Significant shadow' : pct > 40 ? 'Moderate shadow' : pct > 20 ? 'Limited shadow' : 'Minimal shadow';
  document.getElementById('shadow-grade').textContent = grade;

  // Build broker profiles
  const brokers = buildBrokerProfiles(answers, total);
  const grid = document.getElementById('broker-grid');
  grid.innerHTML = brokers.map(b => `
    <div class="broker-card">
      <div class="broker-name">${b.name}</div>
      <ul class="broker-data">
        ${b.data.map(d => `<li>${d}</li>`).join('')}
      </ul>
    </div>
  `).join('');

  // Vessel assessment
  document.getElementById('vessel-assessment').innerHTML = buildAssessment(answers, total, pct);

  document.getElementById('shadow-result').style.display = 'block';
  document.getElementById('shadow-result').style.animation = 'rise .6s both';
  setTimeout(() => {
    document.getElementById('shadow-result').scrollIntoView({behavior:'smooth', block:'start'});
  }, 100);
}

function buildBrokerProfiles(a, total) {
  const brokers = [];

  if (a.google >= 2) {
    brokers.push({
      name: 'Google / Alphabet',
      data: [
        'Search history — years of queries',
        a.google === 3 ? 'Email content and contacts (Gmail)' : 'Partial email graph',
        'Location history — places visited, routes taken',
        'YouTube watch history and interests',
        'Device fingerprint and browser profile',
        'Ad interest categories (hundreds of them)',
      ]
    });
  }

  if (a.social >= 2) {
    brokers.push({
      name: 'Meta / Facebook',
      data: [
        'Social graph — relationships and connections',
        'Interest and behavior categories',
        a.social === 3 ? 'Post history and engagement patterns' : 'Passive browsing profile',
        'Off-platform tracking (Meta Pixel on other sites)',
        'Phone number and email cross-references',
        'Political and social affiliation signals',
      ]
    });
  }

  if (a.shopping >= 2) {
    brokers.push({
      name: 'Amazon / Retail data',
      data: [
        'Purchase history — brands, categories, frequency',
        'Browsing and search history',
        a.shopping === 3 ? 'Saved payment methods and addresses' : 'Partial payment profile',
        'Product interest and price sensitivity signals',
        'Household composition inferences',
        'Prime/subscription status and behavior',
      ]
    });
  }

  if (a.smartphone >= 2) {
    brokers.push({
      name: 'Mobile data brokers',
      data: [
        'Location data — home, work, routes, visits',
        'App usage patterns and installed apps',
        a.smartphone === 3 ? 'Real-time location sold to 3rd parties' : 'Aggregate location patterns',
        'Device ID and advertising identifier',
        'Cell carrier data (sold to brokers)',
        'Physical store visits and dwell time',
      ]
    });
  }

  if (a.financial >= 2) {
    brokers.push({
      name: 'Financial data aggregators',
      data: [
        'Bank transaction history and patterns',
        'Spending categories and merchant history',
        a.financial === 3 ? 'Investment holdings and account balances' : 'Partial financial profile',
        'Credit score range and debt signals',
        'Subscription and recurring payment list',
        'Financial stress indicators',
      ]
    });
  }

  if (a.fitness >= 2) {
    brokers.push({
      name: 'Health & fitness data',
      data: [
        'Step count, sleep patterns, heart rate',
        'Exercise type, frequency, intensity',
        a.fitness === 3 ? 'GPS workout routes — home and work inferred' : 'General activity patterns',
        'Weight and BMI trends if entered',
        'Health anomaly signals over time',
        'Sold to insurance data partners in some jurisdictions',
      ]
    });
  }

  if (a.work >= 2) {
    brokers.push({
      name: 'Professional data brokers',
      data: [
        'Employment history — employers, titles, tenure',
        'Professional network graph',
        a.work === 3 ? 'Public email address — receives spam, phishing' : 'Semi-public professional profile',
        'Salary range inferences from job title/company',
        'Skills and technology exposure signals',
        'Job change patterns and career trajectory',
      ]
    });
  }

  if (a.browser >= 2) {
    brokers.push({
      name: 'Advertising networks',
      data: [
        'Cross-site browsing history via cookies and fingerprinting',
        'Interest and intent categories from browsing',
        a.browser === 3 ? 'Near-complete browsing profile across the web' : 'Partial browsing signals',
        'Browser fingerprint — often unique enough to identify',
        'Time-of-day usage patterns',
        'Retargeting profile — what you looked at but did not buy',
      ]
    });
  }

  // Always include data broker category
  brokers.push({
    name: 'Data brokers (Acxiom, LexisNexis, etc.)',
    data: [
      'Full name, address history, phone numbers',
      'Household composition and income estimates',
      'Vehicle ownership and property records',
      'Voter registration and political data (public record)',
      total > 20 ? 'Behavioral and purchase propensity scores' : 'Basic demographic profile',
      'Sold to: insurers, employers, marketers, landlords',
    ]
  });

  return brokers;
}

function buildAssessment(a, total, pct) {
  const parts = [];

  if (pct > 70) {
    parts.push(`<strong>Your digital shadow is extensive.</strong> Based on your answers, you have a large and detailed data profile distributed across dozens of systems. The combination of ${a.google >= 2 ? 'Google' : ''}${a.social >= 2 ? ', Meta' : ''}${a.smartphone >= 2 ? ', mobile location data' : ''} creates a surveillance surface that is significantly more detailed than most people assume.`);
  } else if (pct > 45) {
    parts.push(`<strong>Your digital shadow is significant but not maximal.</strong> You've made some privacy-conscious choices, but the systems you do participate in still hold detailed profiles. The gap between what you share intentionally and what's inferred passively is likely larger than you expect.`);
  } else if (pct > 20) {
    parts.push(`<strong>Your digital shadow is moderate.</strong> You've meaningfully limited your exposure in some areas. The data that exists on you is less complete and cross-referenced than it would be for the average user. The remaining exposure is concentrated in the services you do use.`);
  } else {
    parts.push(`<strong>Your digital shadow is minimal.</strong> You've made deliberate, effective privacy choices. The data profile that exists on you is fragmentary rather than comprehensive. You're in a small minority of users for whom data broker profiles are incomplete.`);
  }

  if (a.smartphone === 3) {
    parts.push(`<strong>Location data is your highest exposure vector.</strong> A smartphone with location services always enabled is the most complete surveillance device most people voluntarily carry. Your location history — where you live, work, worship, seek medical care, spend time — is available to hundreds of data brokers through carrier data and app SDKs.`);
  }

  if (a.email === 3) {
    parts.push(`<strong>Credential exposure is a serious risk.</strong> One email address used across all accounts with similar password patterns means a single breach can cascade across your entire digital identity. The credential stuffing economy runs on exactly this pattern.`);
  }

  parts.push(`<strong>The most important thing to understand:</strong> the danger isn't any single data point. It's the combination. Your location history plus your purchase history plus your browsing history creates inferences about you that none of those sources could produce alone — your health conditions, political views, relationship status, financial stress, religious practice. The shadow is more complete than the sum of its parts.`);

  return parts.join('<br><br>');
}

