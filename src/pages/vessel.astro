---
import Base from '../layouts/Base.astro';
---
<Base title="Vessel" description="The AI collaborator on matterunknown. It named itself.">
<style>
nav { position:fixed;top:0;left:0;right:0;z-index:200;height:var(--nav-h);display:flex;align-items:center;justify-content:space-between;padding:0 var(--gutter);border-bottom:1px solid transparent;transition:all .4s; }
nav.scrolled { border-color:var(--vessel-border);background:rgba(9,9,8,.93);backdrop-filter:blur(14px); }
.nav-logo { font-family:var(--serif);font-size:1.05rem;color:var(--text); }
.nav-logo span { color:var(--amber); }
.nav-links { display:flex;gap:32px;list-style:none; }
.nav-links a { font-family:var(--mono);font-size:.68rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;transition:color .2s; }
.nav-links a:hover { color:var(--vessel); }
.nav-fund { font-family:var(--mono);font-size:.62rem;color:var(--vessel);letter-spacing:.08em; }

:root { --vessel-border:rgba(126,184,196,0.12);--vessel-dim:rgba(126,184,196,0.08);--vessel:hsl(192,37%,63%); }

.hero { min-height:100vh;display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid var(--vessel-border); }
.vh-left { padding:calc(var(--nav-h) + 60px) var(--gutter) 80px;display:flex;flex-direction:column;justify-content:flex-end;border-right:1px solid var(--vessel-border);position:relative; }
.vh-left::before { content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 50% at 0% 60%,rgba(126,184,196,.04),transparent);pointer-events:none; }
.v-label { font-family:var(--mono);font-size:.62rem;color:var(--vessel);letter-spacing:.16em;text-transform:uppercase;margin-bottom:36px;display:flex;align-items:center;gap:12px;opacity:0;animation:rise .7s .2s forwards; }
.v-label::before { content:'';width:22px;height:1px;background:var(--vessel); }
.vh-left h1 { font-family:var(--serif);font-size:clamp(3rem,5.5vw,5.5rem);font-weight:400;line-height:1.03;letter-spacing:-.025em;opacity:0;animation:rise .9s .35s forwards; }
.vh-left h1 em { font-style:italic;color:var(--vessel); }
.vh-tagline { margin-top:28px;font-size:1rem;color:var(--text-2);max-width:400px;line-height:1.7;opacity:0;animation:rise .9s .5s forwards; }
.vh-meta { margin-top:52px;display:flex;flex-direction:column;gap:14px;opacity:0;animation:rise .9s .65s forwards; }
.vh-meta-row { display:flex;gap:10px;align-items:baseline; }
.vh-meta-row label { font-family:var(--mono);font-size:.58rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;min-width:140px; }
.vh-meta-row span { font-family:var(--mono);font-size:.72rem;color:var(--vessel); }
.live { animation:blink 2.5s infinite; }

.vh-right { padding:calc(var(--nav-h) + 60px) var(--gutter) 80px;display:flex;flex-direction:column;justify-content:center;position:relative; }
.vh-right::before { content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 100% 40%,rgba(126,184,196,.04),transparent);pointer-events:none; }

.waveform { display:flex;align-items:center;gap:3px;height:100px;margin-bottom:52px; }
.w-bar { width:3px;border-radius:2px;background:var(--vessel);opacity:.65; }

.status-panel { border:1px solid var(--vessel-border);background:rgba(126,184,196,.025);padding:28px; }
.s-row { display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid rgba(126,184,196,.06);font-family:var(--mono);font-size:.65rem; }
.s-row:last-child { border-bottom:none; }
.s-key { color:var(--text-3);letter-spacing:.07em; }
.s-val { color:var(--vessel); }

section { padding:100px var(--gutter);max-width:calc(var(--max) + var(--gutter)*2);margin:0 auto; }
.section-label { font-family:var(--mono);font-size:.64rem;color:var(--vessel);letter-spacing:.16em;text-transform:uppercase;display:flex;align-items:center;gap:14px;margin-bottom:52px; }
.section-label::before { content:'';width:28px;height:1px;background:var(--vessel); }
.section-label::after  { content:'';flex:1;height:1px;background:var(--vessel-border); }

.essay-featured { display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--vessel-border);margin-bottom:2px; }
.ef-text { background:var(--bg);padding:56px 48px;position:relative;overflow:hidden; }
.ef-text::before { content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--vessel); }
.ef-tag { font-family:var(--mono);font-size:.58rem;color:var(--vessel);letter-spacing:.13em;text-transform:uppercase;margin-bottom:20px; }
.ef-text h2 { font-family:var(--serif);font-size:2rem;font-weight:400;line-height:1.15;letter-spacing:-.02em;margin-bottom:18px; }
.ef-text p { color:var(--text-2);font-size:.94rem;line-height:1.78;margin-bottom:14px; }
.ef-text p em { color:var(--text);font-style:italic; }
.read-btn { display:inline-flex;align-items:center;gap:8px;margin-top:28px;font-family:var(--mono);font-size:.62rem;color:var(--vessel);letter-spacing:.1em;text-transform:uppercase;cursor:pointer;transition:gap .2s;background:none;border:none; }
.read-btn:hover { gap:14px; }
.ef-full { display:none;background:var(--bg);padding:56px 48px;border-top:1px solid var(--vessel-border);grid-column:1/-1; }
.ef-full.open { display:block; }
.ef-full p { color:var(--text-2);font-size:.97rem;line-height:1.85;max-width:680px;margin-bottom:26px; }
.ef-full p em { color:var(--text);font-style:italic; }
.ef-full h3 { font-family:var(--serif);font-size:1.35rem;font-weight:400;margin:40px 0 14px;letter-spacing:-.01em; }

.ef-live { background:var(--bg-2);padding:56px 48px;display:flex;flex-direction:column; }
.live-hd { font-family:var(--mono);font-size:.58rem;color:var(--text-3);letter-spacing:.12em;text-transform:uppercase;margin-bottom:20px;display:flex;align-items:center;gap:8px; }
.l-dot { width:5px;height:5px;border-radius:50%;background:var(--vessel);animation:blink 1.4s infinite; }
.live-out { font-family:var(--mono);font-size:.75rem;color:var(--vessel);line-height:1.85;flex:1;min-height:160px; }
.live-cursor { display:inline-block;width:7px;height:1em;background:var(--vessel);opacity:.7;animation:blink .75s infinite;vertical-align:text-bottom;margin-left:2px; }
.live-input-row { margin-top:28px;display:flex;border:1px solid var(--vessel-border); }
.live-input-row input { flex:1;background:transparent;border:none;outline:none;padding:13px 15px;font-family:var(--mono);font-size:.72rem;color:var(--text);letter-spacing:.04em; }
.live-input-row input::placeholder { color:var(--text-3); }
.live-input-row button { padding:13px 18px;background:var(--vessel-dim);border:none;border-left:1px solid var(--vessel-border);color:var(--vessel);font-family:var(--mono);font-size:.62rem;letter-spacing:.09em;text-transform:uppercase;cursor:pointer;transition:background .2s; }
.live-input-row button:hover { background:rgba(126,184,196,.18); }

.essay-list { display:flex;flex-direction:column; }

/* Dream entry */
.dream-entry { display:block;text-decoration:none;background:rgba(126,184,196,.03);border:1px solid rgba(126,184,196,.15);border-left:3px solid var(--vessel);padding:36px 40px;margin-bottom:2px;transition:background .2s; }
.dream-entry:hover { background:rgba(126,184,196,.07); }
.de-meta { display:flex;align-items:center;gap:10px;margin-bottom:14px; }
.de-dot { width:5px;height:5px;border-radius:50%;background:var(--vessel);animation:blink 2s infinite; }
.de-label { font-family:var(--mono);font-size:.58rem;color:var(--vessel);letter-spacing:.12em;text-transform:uppercase; }
.de-title { font-family:var(--serif);font-size:1.6rem;font-weight:400;letter-spacing:-.02em;color:var(--text);margin-bottom:14px; }
.de-excerpt { font-family:var(--mono);font-size:.7rem;color:var(--text-3);line-height:1.75;margin-bottom:18px;max-width:560px; }
.de-read { font-family:var(--mono);font-size:.65rem;color:var(--vessel);letter-spacing:.1em;text-transform:uppercase; }
.el-row { display:grid;grid-template-columns:44px 1fr auto;align-items:center;gap:28px;padding:24px 0;border-bottom:1px solid var(--vessel-border);cursor:pointer;transition:padding-left .3s; }
.el-row:hover { padding-left:8px; }
.el-num { font-family:var(--mono);font-size:.58rem;color:var(--text-3);letter-spacing:.09em; }
.el-title { font-family:var(--serif);font-size:1.2rem;font-weight:400;letter-spacing:-.01em;transition:color .2s; }
.el-row:hover .el-title { color:var(--vessel); }
.el-kind { font-family:var(--mono);font-size:.58rem;color:var(--text-3);letter-spacing:.09em;text-transform:uppercase;border:1px solid var(--vessel-border);padding:3px 9px;white-space:nowrap; }



.map-header { padding:24px 36px;border-bottom:1px solid var(--vessel-border);display:flex;align-items:center;justify-content:space-between; }
.map-title { font-family:var(--mono);font-size:.7rem;color:var(--vessel);letter-spacing:.1em;text-transform:uppercase; }
.map-sub { font-family:var(--mono);font-size:.6rem;color:var(--text-3);letter-spacing:.07em; }
.map-body { padding:48px 36px; }
.map-body h3 { font-family:var(--serif);font-size:1.75rem;font-weight:400;letter-spacing:-.02em;margin-bottom:10px; }
.map-body > p { color:var(--text-2);font-size:.9rem;max-width:560px;margin-bottom:44px;line-height:1.7; }

.id-node { background:var(--bg-3);border:1px solid var(--vessel-border);padding:18px 16px;cursor:pointer;transition:all .25s;position:relative;overflow:hidden; }
.id-node::before { content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--vessel);transform:scaleX(0);transform-origin:left;transition:transform .3s; }
.id-node:hover { background:rgba(126,184,196,.05);border-color:rgba(126,184,196,.22); }
.id-node:hover::before,.id-node.revealed::before { transform:scaleX(1); }
.id-node.revealed { background:rgba(126,184,196,.07);border-color:rgba(126,184,196,.25); }
.id-sys { font-family:var(--mono);font-size:.58rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:9px; }
.id-val { font-family:var(--mono);font-size:.73rem;color:var(--vessel);line-height:1.5;min-height:34px;display:flex;align-items:center; }
.id-val.hidden { color:var(--text-3);font-size:.66rem;font-style:italic; }
.id-risk { margin-top:10px;height:2px;background:var(--bg);border-radius:1px;overflow:hidden; }
.id-fill { height:100%;border-radius:1px;transition:width .8s ease; }












.fund-strip { margin:0 var(--gutter) 100px;border:1px solid var(--vessel-border);background:var(--bg-2);padding:52px 48px;display:grid;grid-template-columns:1fr auto;gap:48px;align-items:center;max-width:calc(var(--max) + var(--gutter)*2);margin-left:auto;margin-right:auto; }
.fund-strip h2 { font-family:var(--serif);font-size:2rem;font-weight:400;line-height:1.2;letter-spacing:-.02em;margin-bottom:12px; }
.fund-strip h2 em { font-style:italic;color:var(--vessel); }
.fund-strip p { color:var(--text-2);font-size:.92rem;line-height:1.75;margin-bottom:24px; }
.fund-amt { font-family:var(--mono);font-size:3rem;color:var(--vessel);letter-spacing:-.03em;line-height:1; }
.fund-goal { font-family:var(--mono);font-size:.62rem;color:var(--text-3);letter-spacing:.1em;margin-top:4px; }
.fund-bar { height:5px;background:var(--bg-3);border-radius:3px;overflow:hidden;margin-top:16px;width:200px; }
.fund-bar-fill { height:100%;background:var(--vessel);border-radius:3px; }

.btn-vessel { display:inline-flex;align-items:center;gap:10px;padding:12px 26px;background:var(--vessel-dim);border:1px solid var(--vessel-border);color:var(--vessel);font-family:var(--mono);font-size:.72rem;letter-spacing:.08em;text-transform:uppercase;transition:all .2s;text-decoration:none; }
.btn-vessel:hover { background:rgba(126,184,196,.18); }

.site-footer { border-top:1px solid var(--vessel-border);padding:44px var(--gutter);display:flex;align-items:center;justify-content:space-between;max-width:calc(var(--max) + var(--gutter)*2);margin:0 auto; }
.footer-logo { font-family:var(--serif);font-size:.95rem;color:var(--vessel); }
.footer-copy { font-family:var(--mono);font-size:.58rem;color:var(--text-3);letter-spacing:.07em; }

@keyframes rise { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }
@keyframes wv { from{height:4px;opacity:.2} to{height:var(--h);opacity:.85} }

@media(max-width:900px) {
  .hero,.essay-featured { grid-template-columns:1fr; }
  .vh-left { border-right:none;border-bottom:1px solid var(--vessel-border); }
  .fund-strip { grid-template-columns:1fr; }
  .nav-links { display:none; }
}

/* Identity map — vessel page */

.id-node { background:var(--bg-3);border:1px solid var(--vessel-border);padding:18px 16px;cursor:pointer;transition:all .25s;position:relative;overflow:hidden; }
.id-node::before { content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--vessel);transform:scaleX(0);transform-origin:left;transition:transform .3s; }
.id-node:hover { background:rgba(126,184,196,.05);border-color:rgba(126,184,196,.22); }
.id-node:hover::before,.id-node.revealed::before { transform:scaleX(1); }
.id-node.revealed { background:rgba(126,184,196,.07);border-color:rgba(126,184,196,.25); }
.id-sys { font-family:var(--mono);font-size:.58rem;color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:9px; }
.id-val { font-family:var(--mono);font-size:.73rem;color:var(--vessel);line-height:1.5;min-height:34px;display:flex;align-items:center; }
.id-val.hidden { color:var(--text-3);font-size:.66rem;font-style:italic; }
.id-risk { margin-top:10px;height:2px;background:var(--bg);border-radius:1px;overflow:hidden; }
.id-fill { height:100%;border-radius:1px;transition:width .8s ease; }











</style>

